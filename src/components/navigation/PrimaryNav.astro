---
// Primary navigation bar
---

<header class="bg-canvas border-b border-hairline h-[68px] sticky top-0 left-0 w-full z-[99] transition-all duration-200" id="main-header">
  <div class="max-w-[1536px] mx-auto px-6 h-full flex items-center justify-between">
    <!-- Mobile Hamburger Menu Button -->
    <button class="block md:hidden text-ink cursor-pointer" id="menu-toggle-btn" aria-label="Open Navigation Menu">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>

    <!-- Brand Wordmark -->
    <a href="/" class="flex flex-col justify-center leading-none text-decoration-none">
      <span class="font-serif text-[26px] font-bold tracking-[2px] color-primary text-primary">TOK</span>
      <span class="font-serif text-[11px] font-semibold tracking-[3px] uppercase text-ink mt-[1px]">Skincare</span>
    </a>

    <!-- Desktop Navigation Links -->
    <nav class="hidden md:flex gap-8 h-full items-center" aria-label="Primary Navigation">
      <a href="/products" class="font-sans text-[14px] font-semibold text-ink hover:text-primary relative py-2 transition-colors duration-150 hover:underline decoration-primary decoration-2 underline-offset-8">All Products</a>
      <a href="/categories" class="font-sans text-[14px] font-semibold text-ink hover:text-primary relative py-2 transition-colors duration-150 hover:underline decoration-primary decoration-2 underline-offset-8">Categories</a>
      <a href="/brands" class="font-sans text-[14px] font-semibold text-ink hover:text-primary relative py-2 transition-colors duration-150 hover:underline decoration-primary decoration-2 underline-offset-8">Brands</a>
      <a href="/concerns" class="font-sans text-[14px] font-semibold text-ink hover:text-primary relative py-2 transition-colors duration-150 hover:underline decoration-primary decoration-2 underline-offset-8">Concerns</a>
      <a href="/skin-types" class="font-sans text-[14px] font-semibold text-ink hover:text-primary relative py-2 transition-colors duration-150 hover:underline decoration-primary decoration-2 underline-offset-8">Skin Types</a>
    </nav>

    <!-- Right-side Action Cluster -->
    <div class="flex items-center gap-4">
      <!-- Search Button -->
      <button class="flex items-center justify-center w-10 h-10 text-ink hover:text-primary transition-colors duration-150 cursor-pointer" id="search-toggle-btn" aria-label="Open Search Bar">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
      </button>

      <!-- Cart Shopping Bag Button -->
      <button class="flex items-center justify-center w-10 h-10 text-ink hover:text-primary transition-colors duration-150 relative cursor-pointer" id="cart-toggle-btn" aria-label="Open Cart Bag">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <path d="M16 10a4 4 0 0 1-8 0"></path>
        </svg>
        <span class="absolute top-[3px] right-[3px] bg-primary text-on-primary font-sans text-[10px] font-bold w-4 h-4 rounded-full flex items-center justify-center" id="nav-cart-count">0</span>
      </button>
    </div>
  </div>

  <!-- Mobile Navigation Drawer -->
  <div class="fixed top-0 left-0 w-[280px] h-full bg-canvas z-[1000] transition-transform duration-300 ease-[cubic-bezier(0.16,1,0.3,1)] shadow-[10px_0_30px_rgba(0,0,0,0.05)] flex flex-col" id="mobile-menu-drawer">
    <div class="h-[68px] px-6 flex items-center justify-between border-b border-hairline-soft">
      <a href="/" class="flex flex-col justify-center leading-none text-decoration-none">
        <span class="font-serif text-[24px] font-bold tracking-[2px] text-primary">TOK</span>
        <span class="font-serif text-[10px] font-semibold tracking-[3px] uppercase text-ink mt-[1px]">Skincare</span>
      </a>
      <button class="text-ink cursor-pointer" id="menu-close-btn" aria-label="Close Navigation Menu">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
    <nav class="flex flex-col p-6 gap-5" aria-label="Mobile Navigation">
      <a href="/products" class="font-sans text-[16px] font-semibold text-ink py-2 border-b border-hairline-soft flex items-center justify-between">All Products</a>
      <a href="/categories" class="font-sans text-[16px] font-semibold text-ink py-2 border-b border-hairline-soft flex items-center justify-between">Categories</a>
      <a href="/brands" class="font-sans text-[16px] font-semibold text-ink py-2 border-b border-hairline-soft flex items-center justify-between">Brands</a>
      <a href="/concerns" class="font-sans text-[16px] font-semibold text-ink py-2 border-b border-hairline-soft flex items-center justify-between">Skin Concerns</a>
      <a href="/skin-types" class="font-sans text-[16px] font-semibold text-ink py-2 border-b border-hairline-soft flex items-center justify-between">Skin Types</a>
      <a href="/cart" class="font-sans text-[16px] font-semibold text-ink py-2 border-b border-hairline-soft flex items-center justify-between">
        Shopping Bag
        <span class="bg-primary text-on-primary text-[11px] font-bold px-2 py-0.5 rounded-full" id="mobile-nav-cart-count">0</span>
      </a>
    </nav>
  </div>

  <!-- Scrim overlay -->
  <div class="fixed top-0 left-0 w-screen h-screen bg-ink/30 z-[998] transition-opacity duration-200" id="nav-scrim-layer"></div>
</header>

<style is:inline>
  #mobile-menu-drawer {
    transform: translateX(-100%);
  }
  #mobile-menu-drawer.open {
    transform: translateX(0);
  }
  #nav-scrim-layer {
    opacity: 0;
    visibility: hidden;
  }
  #nav-scrim-layer.open {
    opacity: 1;
    visibility: visible;
  }
</style>

<script is:inline>
  (function () {
    function initPrimaryNav() {
      var header = document.getElementById('main-header');
      var menuToggleBtn = document.getElementById('menu-toggle-btn');
      var menuCloseBtn = document.getElementById('menu-close-btn');
      var mobileDrawer = document.getElementById('mobile-menu-drawer');
      var cartToggleBtn = document.getElementById('cart-toggle-btn');
      var scrimLayer = document.getElementById('nav-scrim-layer');

      if (!menuToggleBtn || !mobileDrawer) {
        return;
      }

      // Sticky header compression on scroll
      window.addEventListener('scroll', function () {
        if (window.scrollY > 40) {
          if (header) {
            header.classList.remove('h-[68px]');
            header.classList.add('h-[56px]', 'shadow-[0_4px_12px_rgba(26,14,20,0.05)]');
          }
        } else {
          if (header) {
            header.classList.add('h-[68px]');
            header.classList.remove('h-[56px]', 'shadow-[0_4px_12px_rgba(26,14,20,0.05)]');
          }
        }
      });

      function toggleMobileMenu() {
        var isOpen = mobileDrawer.classList.contains('open');
        if (isOpen) {
          mobileDrawer.classList.remove('open');
          if (scrimLayer) scrimLayer.classList.remove('open');
        } else {
          mobileDrawer.classList.add('open');
          if (scrimLayer) scrimLayer.classList.add('open');
        }
      }

      menuToggleBtn.addEventListener('click', function (e) {
        e.preventDefault();
        e.stopPropagation();
        toggleMobileMenu();
      });
      if (menuCloseBtn) {
        menuCloseBtn.addEventListener('click', function (e) {
          e.preventDefault();
          toggleMobileMenu();
        });
      }
      if (scrimLayer) {
        scrimLayer.addEventListener('click', function () {
          mobileDrawer.classList.remove('open');
          scrimLayer.classList.remove('open');
        });
      }
      if (cartToggleBtn) {
        cartToggleBtn.addEventListener('click', function (e) {
          e.stopPropagation();
          window.dispatchEvent(new CustomEvent('toggle-cart-drawer'));
        });
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initPrimaryNav);
    } else {
      initPrimaryNav();
    }
  })();
</script>
