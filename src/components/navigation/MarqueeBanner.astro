---
import { announcements } from "../../data/announcements";

// Duplicate the items so the CSS -50% translate creates a seamless loop
// without a hard cut at the end of the bar.
const rendered = announcements.concat(announcements);
const separator = " • ";
---

<div class="bg-primary text-on-primary h-[30px] flex items-center overflow-hidden relative z-[100]">
  <div class="marquee-content flex whitespace-nowrap font-sans text-[11px] font-bold tracking-[2px] uppercase absolute will-change-transform">
    {rendered.map((item) => (
      <span>
        {item.href ? <a href={item.href} class="text-on-primary no-underline hover:underline">{item.text}</a> : item.text}
        <span aria-hidden="true">&nbsp;{separator}&nbsp;</span>
      </span>
    ))}
  </div>
</div>

<style>
  .marquee-content {
    animation: marquee-scroll 30s linear infinite;
  }

  .marquee-content > span {
    padding-right: 0;
    display: inline-flex;
    align-items: center;
  }

  @keyframes marquee-scroll {
    0% {
      transform: translateX(0%);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee-content {
      animation: none;
      position: static;
      width: 100%;
      justify-content: center;
      white-space: normal;
      flex-wrap: wrap;
    }
  }
</style>
