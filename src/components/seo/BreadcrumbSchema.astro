---
import type { BreadcrumbItem, JsonLdBreadcrumb } from "../../types/seo";
import JsonLd from "./JsonLd.astro";

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;

const baseUrl = Astro.site?.toString().replace(/\/$/, "") ?? "";
const data: JsonLdBreadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: items.map((item, idx) => ({
    "@type": "ListItem",
    position: idx + 1,
    name: item.label,
    item: item.href ? (item.href.startsWith("http") ? item.href : `${baseUrl}${item.href}`) : undefined,
  })),
};
---

<JsonLd data={data} />
