---
import type { SEOMeta } from "../../types/seo";

interface Props extends SEOMeta {
  siteName?: string;
  twitterHandle?: string;
}

const {
  title,
  description,
  image = "/og/default-og.jpg",
  type = "website",
  canonicalUrl,
  siteName = "TOK Skincare",
  twitterHandle = "@tokskincare",
} = Astro.props;

const url = canonicalUrl || Astro.url.href;
const fullImage = image?.startsWith("http") ? image : new URL(image, Astro.site ?? Astro.url.origin).toString();
---

<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content={type} />
<meta property="og:url" content={url} />
<meta property="og:site_name" content={siteName} />
<meta property="og:image" content={fullImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:locale" content="en_US" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={fullImage} />
<meta name="twitter:site" content={twitterHandle} />
