---
// Slide-in Cart Drawer — offline/localStorage based, no backend dependency.
// Follows Petal DESIGN.md: canvas bg, zero border-radius, serif price, sans body.
---

<div
  class="fixed top-0 right-0 w-[420px] max-w-full h-full bg-canvas z-[1100] shadow-[10px_0_30px_rgba(26,14,20,0.08)] transition-all duration-300 ease-[cubic-bezier(0.16,1,0.3,1)] border-l border-hairline"
  id="cart-drawer-sidebar"
  aria-hidden="true"
  role="dialog"
  aria-modal="true"
  aria-label="Your Shopping Bag"
>
  <div class="flex flex-col h-full relative">
    <!-- Header -->
    <div class="h-[68px] px-6 flex items-center justify-between border-b border-hairline">
      <h2 class="font-sans text-heading-lg font-semibold text-ink">Your Bag (<span id="cart-drawer-count">0</span>)</h2>
      <button class="text-mute w-11 h-11 flex items-center justify-center hover:text-ink transition-colors duration-150 cursor-pointer" id="cart-close-btn" aria-label="Close Shopping Bag">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>

    <!-- Empty State -->
    <div class="grow flex flex-col items-center justify-center p-8 text-center gap-4" id="cart-empty-state">
      <div class="text-stone">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <path d="M16 10a4 4 0 0 1-8 0"></path>
        </svg>
      </div>
      <p class="font-sans text-[15px] text-mute">Your bag is currently empty.</p>
      <a href="/products" class="inline-flex items-center justify-center bg-ink text-on-dark font-sans text-[12px] font-bold tracking-[1px] uppercase h-11 px-6 rounded-none no-underline transition-colors duration-150 hover:bg-primary cursor-pointer" id="empty-shop-btn">Browse Products</a>
    </div>

    <!-- Enriched Item List -->
    <div class="grow overflow-y-auto p-6" id="cart-items-container" style="display: none;">
      <div class="flex flex-col gap-6" id="cart-items-list">
        <!-- Rendered client-side -->
      </div>
    </div>

    <!-- Summary Footer (Sticky to bottom) -->
    <div class="border-t border-hairline p-6 bg-canvas flex flex-col gap-3" id="cart-summary-footer" style="display: none;">
      <div class="flex justify-between items-center font-sans text-[16px] font-bold text-ink">
        <span>Subtotal</span>
        <span class="font-sans text-[20px] text-ink" id="cart-subtotal-val">৳0</span>
      </div>
      <p class="text-[12px] text-mute">Delivery charge calculated during checkout.</p>

      <div class="flex flex-col gap-2 mt-2">
        <a href="/cart" class="flex items-center justify-center bg-primary text-on-primary font-sans text-[13px] font-bold tracking-[1px] uppercase h-12 rounded-none no-underline transition-colors duration-150 hover:bg-primary-pressed cursor-pointer">View Full Bag</a>
        <button class="font-sans text-[11px] font-bold tracking-[1px] text-mute uppercase text-center py-2 hover:text-ink hover:underline cursor-pointer" id="continue-shopping-btn">Continue Shopping</button>
      </div>
    </div>
  </div>
</div>

<!-- Scrim background overlay for Cart Drawer -->
<div class="fixed top-0 left-0 w-screen h-screen bg-ink/40 z-[1090] transition-all duration-250" id="cart-scrim-layer"></div>

<style>
  #cart-drawer-sidebar {
    translate: 100% 0;
  }
  #cart-drawer-sidebar.open {
    translate: none;
  }
  #cart-scrim-layer {
    opacity: 0;
    visibility: hidden;
  }
  #cart-scrim-layer.open {
    opacity: 1;
    visibility: visible;
  }
</style>

<script>
  (function() {
    var STORAGE_KEY = 'tok_cart';
    var sidebar = document.getElementById('cart-drawer-sidebar');
    var scrim = document.getElementById('cart-scrim-layer');
    var closeBtn = document.getElementById('cart-close-btn');
    var continueBtn = document.getElementById('continue-shopping-btn');
    var emptyShopBtn = document.getElementById('empty-shop-btn');
    var emptyState = document.getElementById('cart-empty-state');
    var contentContainer = document.getElementById('cart-items-container');
    var summaryFooter = document.getElementById('cart-summary-footer');
    var itemsList = document.getElementById('cart-items-list');
    var subtotalText = document.getElementById('cart-subtotal-val');
    var countBadge = document.getElementById('cart-drawer-count');

    function readItems() {
      try {
        var raw = localStorage.getItem(STORAGE_KEY);
        if (!raw) return [];
        var parsed = JSON.parse(raw);
        return Array.isArray(parsed) ? parsed : [];
      } catch(e) { return []; }
    }

    function formatBDT(val) {
      return '৳' + val.toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
    }

    // ── Render items from localStorage into the drawer ─────────────
    function renderDrawer() {
      var items = readItems();

      if (items.length === 0) {
        if (emptyState) emptyState.style.display = 'flex';
        if (contentContainer) contentContainer.style.display = 'none';
        if (summaryFooter) summaryFooter.style.display = 'none';
        if (countBadge) countBadge.innerText = '0';
        return;
      }

      if (emptyState) emptyState.style.display = 'none';
      if (contentContainer) contentContainer.style.display = 'block';
      if (summaryFooter) summaryFooter.style.display = 'flex';

      if (itemsList) {
        itemsList.innerHTML = '';
        var subtotal = 0;
        var totalItems = 0;

        items.forEach(function(item) {
          subtotal += item.price * item.quantity;
          totalItems += item.quantity;

          var node = document.createElement('div');
          node.className = 'flex gap-4 pb-6 border-b border-hairline-soft';
          node.innerHTML =
            '<div class="w-[70px] h-[93px] shrink-0 overflow-hidden bg-surface-card border border-hairline-soft">' +
              '<img src="' + item.image + '" alt="' + item.name + '" class="w-full h-full object-cover" />' +
            '</div>' +
            '<div class="grow flex flex-col gap-1">' +
              '<h4 class="font-sans text-[14px] font-semibold text-ink leading-snug line-clamp-2">' + item.name + '</h4>' +
              '<span class="font-sans text-[15px] font-bold text-primary">' + formatBDT(item.price) + '</span>' +
              '<div class="flex items-center justify-between mt-auto">' +
                '<div class="flex items-center border border-hairline rounded-none h-7 bg-surface-soft">' +
                  '<button class="w-7 h-full flex items-center justify-center font-bold text-[12px] text-ink hover:bg-secondary-bg cursor-pointer dec-btn" data-id="' + item.productId + '" aria-label="Decrease quantity">-</button>' +
                  '<span class="w-8 text-center font-sans text-[12px] font-bold">' + item.quantity + '</span>' +
                  '<button class="w-7 h-full flex items-center justify-center font-bold text-[12px] text-ink hover:bg-secondary-bg cursor-pointer inc-btn" data-id="' + item.productId + '" aria-label="Increase quantity">+</button>' +
                '</div>' +
                '<button class="font-sans text-[11px] font-semibold text-mute uppercase tracking-[0.5px] bg-transparent border-none cursor-pointer hover:text-error hover:underline remove-item-btn" data-id="' + item.productId + '" aria-label="Remove item">Remove</button>' +
              '</div>' +
            '</div>';
          itemsList.appendChild(node);
        });

        if (countBadge) countBadge.innerText = totalItems.toString();
        if (subtotalText) subtotalText.innerText = formatBDT(subtotal);
      }
    }

    // ── Toggle drawer open/close ───────────────────────────────────
    function toggleDrawer(open) {
      if (open) {
        renderDrawer(); // Always render fresh data when opening
        sidebar?.classList.add('open');
        sidebar?.setAttribute('aria-hidden', 'false');
        scrim?.classList.add('open');
      } else {
        sidebar?.classList.remove('open');
        sidebar?.setAttribute('aria-hidden', 'true');
        scrim?.classList.remove('open');
      }
    }

    // ── Event listeners ────────────────────────────────────────────

    // Toggle drawer from nav icon or add-to-cart
    window.addEventListener('toggle-cart-drawer', function(e) {
      var isOpen = sidebar?.classList.contains('open');
      var open = e.detail?.open !== undefined ? e.detail.open : !isOpen;
      toggleDrawer(open);
    });

    // Close handlers
    closeBtn?.addEventListener('click', function() { toggleDrawer(false); });
    continueBtn?.addEventListener('click', function() { toggleDrawer(false); });
    emptyShopBtn?.addEventListener('click', function() { toggleDrawer(false); });
    scrim?.addEventListener('click', function() { toggleDrawer(false); });

    // Live update when cart changes (badge + drawer content)
    window.addEventListener('cart-updated', function(e) {
      renderDrawer();
      // Also update nav badge
      var items = e.detail || [];
      var total = items.reduce(function(s, i) { return s + i.quantity; }, 0);
      var badge = document.getElementById('nav-cart-count');
      var mobileBadge = document.getElementById('mobile-nav-cart-count');
      if (badge) badge.innerText = total.toString();
      if (mobileBadge) mobileBadge.innerText = total.toString();
    });

    // ── Item quantity/remove clicks (event delegation) ─────────────
    itemsList?.addEventListener('click', function(e) {
      var target = e.target.closest('button');
      if (!target) return;

      var productId = parseInt(target.getAttribute('data-id'));
      if (isNaN(productId)) return;

      var items = readItems();
      var currentItem = items.find(function(i) { return i.productId === productId; });
      if (!currentItem) return;

      if (target.classList.contains('inc-btn')) {
        currentItem.quantity += 1;
      } else if (target.classList.contains('dec-btn')) {
        currentItem.quantity -= 1;
        if (currentItem.quantity <= 0) {
          items = items.filter(function(i) { return i.productId !== productId; });
        }
      } else if (target.classList.contains('remove-item-btn')) {
        items = items.filter(function(i) { return i.productId !== productId; });
      } else {
        return;
      }

      localStorage.setItem(STORAGE_KEY, JSON.stringify(items));
      renderDrawer(); // Re-render immediately

      // Update badge
      var totalItems = items.reduce(function(s, i) { return s + i.quantity; }, 0);
      var badge = document.getElementById('nav-cart-count');
      var mobileBadge = document.getElementById('mobile-nav-cart-count');
      if (badge) badge.innerText = totalItems.toString();
      if (mobileBadge) mobileBadge.innerText = totalItems.toString();

      // Notify other listeners (cart page, etc)
      window.dispatchEvent(new CustomEvent('cart-updated', { detail: items }));
    });
  })();
</script>
