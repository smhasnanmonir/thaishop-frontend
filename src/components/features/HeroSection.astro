---
import HeroCarousel from "./HeroCarousel.astro";
import type { Slider } from "../../lib/api";

interface Props {
  carousel: Slider[];
  staticImages: Slider[];
}

const { carousel = [], staticImages = [] } = Astro.props;
const hasStatic = staticImages.length > 0;
const staticItems = staticImages.slice(0, 2);
---

<section
  class:list={[
    "grid grid-cols-1 gap-3 md:gap-4",
    hasStatic ? "lg:grid-cols-[1.55fr_1fr]" : "lg:grid-cols-1",
    "lg:h-[460px] xl:h-[520px] 2xl:h-[580px]",
  ]}
>
  {/* Slider */}
  <div class="relative rounded-2xl overflow-hidden h-[300px] sm:h-[360px] md:h-[420px] lg:h-full">
    <HeroCarousel sliders={carousel} class="h-full" />
  </div>

  {/* Static promotional images */}
  {
    hasStatic && (
      <div class="grid grid-cols-2 lg:grid-cols-1 gap-3 md:gap-4 h-full">
        {staticItems.map((img) =>
          img.redirect_url ? (
            <a
              href={img.redirect_url}
              class="relative rounded-2xl overflow-hidden block h-[160px] lg:h-full group"
            >
              <img
                src={img.image_url}
                alt={img.name}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
              />
            </a>
          ) : (
            <div class="relative rounded-2xl overflow-hidden h-[160px] lg:h-full group">
              <img
                src={img.image_url}
                alt={img.name}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
              />
            </div>
          )
        )}
      </div>
    )
  }
</section>
