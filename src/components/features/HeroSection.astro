---
import HeroCarousel from "./HeroCarousel.astro";
import type { Slider } from "../../lib/api";

interface Props {
  carousel: Slider[];
  staticImages: Slider[];
}

const { carousel = [], staticImages = [] } = Astro.props;
const hasStatic = staticImages.length > 0;
const staticItems = staticImages.slice(0, 2);
---

<section
  class:list={[
    "grid grid-cols-1 gap-3 md:gap-4",
    hasStatic ? "lg:grid-cols-[2fr_1fr]" : "lg:grid-cols-1",
  ]}
>
  {/* Slider */}
  <div
    class:list={[
      "relative rounded-2xl overflow-hidden",
      "aspect-[16/9]",
      hasStatic ? "lg:aspect-auto lg:h-full" : "lg:aspect-[16/9]",
    ]}
  >
    <HeroCarousel sliders={carousel} class="h-full" />
  </div>

  {/* Static promotional images */}
  {
    hasStatic && (
      <div class="grid grid-cols-2 lg:grid-cols-1 gap-3 md:gap-4">
        {staticItems.map((img) =>
          img.redirect_url ? (
            <a
              href={img.redirect_url}
              class="relative rounded-2xl overflow-hidden block aspect-[16/9] group"
            >
              <img
                src={img.image_url}
                alt={img.name}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
              />
            </a>
          ) : (
            <div class="relative rounded-2xl overflow-hidden aspect-[16/9] group">
              <img
                src={img.image_url}
                alt={img.name}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
              />
            </div>
          )
        )}
      </div>
    )
  }
</section>
