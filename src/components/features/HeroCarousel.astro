---
import type { Slider } from "../../lib/api";

interface Props {
  sliders: Slider[];
  class?: string;
}

const { sliders = [], class: className = "" } = Astro.props;

const fallbackSliders: Slider[] = [
  {
    id: 1,
    name: "Sawasdee! Pure Thai Radiance",
    slug: "fallback-slide-1",
    image_url: "https://images.unsplash.com/photo-1556228578-0d85b1a4d571?q=80&w=1200&auto=format&fit=crop",
    redirect_url: "/products",
    display_order: 1,
  },
  {
    id: 2,
    name: "Apothecary Skincare Traditions",
    slug: "fallback-slide-2",
    image_url: "https://images.unsplash.com/photo-1608248597279-f99d160bfcbc?q=80&w=1200&auto=format&fit=crop",
    redirect_url: "/products",
    display_order: 2,
  },
];

const items = sliders.length > 0 ? sliders : fallbackSliders;
---

<div
  class:list={["relative w-full overflow-hidden", className]}
  aria-roledescription="carousel"
  aria-label="Featured Promotions"
>
  <div class="w-full h-full relative">
    {
      items.map((slide, index) => (
        <div
          class:list={[
            "absolute inset-0 w-full h-full flex items-center transition-all duration-700 ease-in-out",
            index === 0 ? "opacity-100 visible z-[2]" : "opacity-0 invisible z-0",
          ]}
          data-slide-index={index}
          role="group"
          aria-roledescription="slide"
          aria-label={`${index + 1} of ${items.length}`}
        >
          {slide.redirect_url ? (
            <a href={slide.redirect_url} class="w-full h-full block">
              <img
                src={slide.image_url}
                alt={slide.name}
                class="w-full h-full object-cover object-center"
              />
            </a>
          ) : (
            <img
              src={slide.image_url}
              alt={slide.name}
              class="w-full h-full object-cover object-center"
            />
          )}
        </div>
      ))
    }
  </div>

  {/* Navigation Paddles */}
  <button
    class="absolute top-1/2 -translate-y-1/2 left-4 w-11 h-11 bg-canvas text-ink flex items-center justify-center z-10 border border-hairline rounded-none shadow-sm transition-colors duration-150 hover:bg-primary hover:text-on-primary hover:border-primary hidden md:flex cursor-pointer"
    id="carousel-prev"
    aria-label="Previous Slide"
  >
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <polyline points="15 18 9 12 15 6"></polyline>
    </svg>
  </button>
  <button
    class="absolute top-1/2 -translate-y-1/2 right-4 w-11 h-11 bg-canvas text-ink flex items-center justify-center z-10 border border-hairline rounded-none shadow-sm transition-colors duration-150 hover:bg-primary hover:text-on-primary hover:border-primary hidden md:flex cursor-pointer"
    id="carousel-next"
    aria-label="Next Slide"
  >
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <polyline points="9 18 15 12 9 6"></polyline>
    </svg>
  </button>

  {/* Slide Indicators */}
  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 flex gap-1.5 z-10">
    {
      items.map((_, index) => (
        <button
          class:list={[
            "indicator w-2 h-2 rounded-full p-0 transition-all duration-200 cursor-pointer",
            index === 0
              ? "bg-primary scale-125"
              : "bg-on-dark/30",
          ]}
          data-indicator-index={index}
          aria-label={`Go to slide ${index + 1}`}
        />
      ))
    }
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const carousel = document.querySelector('[aria-roledescription="carousel"]');
    if (!carousel) return;

    const slides = carousel.querySelectorAll("[data-slide-index]");
    const indicators = carousel.querySelectorAll(".indicator");
    const prevBtn = carousel.querySelector("#carousel-prev");
    const nextBtn = carousel.querySelector("#carousel-next");

    let currentIdx = 0;
    const totalSlides = slides.length;
    let autoPlayTimer: number;

    function showSlide(index: number) {
      let targetIdx = index;
      if (index >= totalSlides) targetIdx = 0;
      if (index < 0) targetIdx = totalSlides - 1;

      slides.forEach((slide, i) => {
        if (i === targetIdx) {
          slide.classList.remove("opacity-0", "invisible", "z-0");
          slide.classList.add("opacity-100", "visible", "z-[2]");
        } else {
          slide.classList.remove("opacity-100", "visible", "z-[2]");
          slide.classList.add("opacity-0", "invisible", "z-0");
        }
      });

      indicators.forEach((indicator, i) => {
        if (i === targetIdx) {
          indicator.classList.remove("bg-on-dark/30", "scale-100");
          indicator.classList.add("bg-primary", "scale-125");
        } else {
          indicator.classList.remove("bg-primary", "scale-125");
          indicator.classList.add("bg-on-dark/30", "scale-100");
        }
      });

      currentIdx = targetIdx;
      resetAutoPlay();
    }

    function nextSlide() {
      showSlide(currentIdx + 1);
    }

    function prevSlide() {
      showSlide(currentIdx - 1);
    }

    prevBtn?.addEventListener("click", prevSlide);
    nextBtn?.addEventListener("click", nextSlide);

    indicators.forEach((indicator) => {
      indicator.addEventListener("click", () => {
        const indexStr = indicator.getAttribute("data-indicator-index");
        if (indexStr !== null) {
          showSlide(parseInt(indexStr));
        }
      });
    });

    function startAutoPlay() {
      autoPlayTimer = window.setInterval(nextSlide, 6000);
    }

    function resetAutoPlay() {
      if (autoPlayTimer) clearInterval(autoPlayTimer);
      startAutoPlay();
    }

    startAutoPlay();
  });
</script>
