---
// Tabbed suggestions component for the homepage using Tailwind CSS v4
---

<div class="flex flex-col gap-6 tabbed-suggestions">
  <div class="flex justify-center border-b border-hairline gap-4 overflow-x-auto pb-[1px] scrollbar-none" id="tabs-header-list">
    <button class="font-sans text-[14px] font-semibold text-mute px-6 py-2 border-b-2 border-transparent cursor-pointer whitespace-nowrap transition-colors duration-150 hover:text-ink tab-btn active" data-tab-type="skin-concern" data-tab-value="acne" aria-selected="true" role="tab">
      Acne Care
    </button>
    <button class="font-sans text-[14px] font-semibold text-mute px-6 py-2 border-b-2 border-transparent cursor-pointer whitespace-nowrap transition-colors duration-150 hover:text-ink tab-btn" data-tab-type="skin-type" data-tab-value="oily" aria-selected="false" role="tab">
      Oily Skin
    </button>
    <button class="font-sans text-[14px] font-semibold text-mute px-6 py-2 border-b-2 border-transparent cursor-pointer whitespace-nowrap transition-colors duration-150 hover:text-ink tab-btn" data-tab-type="skin-type" data-tab-value="sensitive" aria-selected="false" role="tab">
      Sensitive Skin
    </button>
    <button class="font-sans text-[14px] font-semibold text-mute px-6 py-2 border-b-2 border-transparent cursor-pointer whitespace-nowrap transition-colors duration-150 hover:text-ink tab-btn" data-tab-type="skin-concern" data-tab-value="brightening" aria-selected="false" role="tab">
      Brightening
    </button>
  </div>

  <div class="relative min-h-[320px]">
    <!-- Shimmer Loader Grid -->
    <div class="grid grid-cols-2 sm:grid-cols-2 lg:grid-cols-6 gap-3 sm:gap-6" id="suggestions-shimmer">
      <div class="h-[380px] bg-linear-to-r from-surface-soft via-secondary-bg to-surface-soft bg-[length:200%_100%] animate-shimmer rounded-lg"></div>
      <div class="h-[380px] bg-linear-to-r from-surface-soft via-secondary-bg to-surface-soft bg-[length:200%_100%] animate-shimmer rounded-lg"></div>
      <div class="h-[380px] bg-linear-to-r from-surface-soft via-secondary-bg to-surface-soft bg-[length:200%_100%] animate-shimmer rounded-lg"></div>
      <div class="h-[380px] bg-linear-to-r from-surface-soft via-secondary-bg to-surface-soft bg-[length:200%_100%] animate-shimmer rounded-lg"></div>
      <div class="h-[380px] bg-linear-to-r from-surface-soft via-secondary-bg to-surface-soft bg-[length:200%_100%] animate-shimmer rounded-lg"></div>
      <div class="h-[380px] bg-linear-to-r from-surface-soft via-secondary-bg to-surface-soft bg-[length:200%_100%] animate-shimmer rounded-lg"></div>
    </div>

    <!-- Error/Empty state -->
    <div class="text-center py-12 font-sans text-mute" id="suggestions-empty" style="display: none;">
      <p>No products found for this routine. Please explore other ranges.</p>
    </div>

    <!-- Dynamic Grid -->
    <div class="grid grid-cols-2 sm:grid-cols-2 lg:grid-cols-6 gap-3 sm:gap-6 opacity-0 translate-y-2" id="suggestions-grid" style="display: none;">
      <!-- Content populated client-side -->
    </div>
  </div>
</div>

<style>
  /* Scrollbar hiding utilities */
  #tabs-header-list {
    scrollbar-width: none;
  }
  #tabs-header-list::-webkit-scrollbar {
    display: none;
  }
  
  .tab-btn.active {
    color: var(--color-primary);
    border-bottom-color: var(--color-primary);
  }

  @keyframes shimmer-anim {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }
  .animate-shimmer {
    animation: shimmer-anim 1.5s infinite;
  }

  /* Entrance animation for dynamic grids */
  #suggestions-grid.open {
    display: grid !important;
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.4s ease-out, transform 0.4s ease-out;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const component = document.querySelector('.tabbed-suggestions');
    if (!component) return;

    const tabButtons = component.querySelectorAll('.tab-btn');
    const shimmer = document.getElementById('suggestions-shimmer');
    const emptyState = document.getElementById('suggestions-empty');
    const grid = document.getElementById('suggestions-grid');

    // BDT Price Formatter helper
    function formatBDT(val: number) {
      return '৳' + val.toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
    }

    async function loadTabProducts(type: string, value: string) {
      if (shimmer) shimmer.style.display = 'grid';
      if (grid) {
        grid.style.display = 'none';
        grid.classList.remove('open');
      }
      if (emptyState) emptyState.style.display = 'none';

      let url = `https://backend.tokbd.com/api/products/search/skin-concern/${value}?pageSize=6`;
      if (type === 'skin-type') {
        url = `https://backend.tokbd.com/api/products/search/skin-type/${value}?pageSize=6`;
      }

      try {
        const res = await fetch(url);
        if (res.ok) {
          const data = await res.json();
          const products = data.result || [];

          if (shimmer) shimmer.style.display = 'none';

          if (products.length === 0) {
            if (emptyState) emptyState.style.display = 'block';
            return;
          }

          if (grid) {
            grid.innerHTML = '';
            
            products.forEach((prod: any) => {
              const currentPrice = parseFloat(prod.price);
              const originalPrice = parseFloat(prod.origin_price);
              const onSale = originalPrice > currentPrice;
              const discountPercent = onSale ? Math.round(((originalPrice - currentPrice) / originalPrice) * 100) : 0;
              const imgUrl = prod.card_photo || prod.img || "https://images.unsplash.com/photo-1608248597279-f99d160bfcbc?q=80&w=400&auto=format&fit=crop";

              const card = document.createElement('div');
              card.className = 'group flex flex-col bg-white border border-hairline-soft rounded-none';
              card.setAttribute('data-id', prod.id);

              card.innerHTML = `
                <a href="/products/${prod.slug}" class="block relative" aria-label="View details for ${prod.name}">
                  <div class="relative w-full aspect-square sm:aspect-[3/4] bg-surface-card overflow-hidden">
                    <img src="${imgUrl}" alt="${prod.name}" class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
                    <div class="absolute top-3 left-3 flex flex-col gap-1.5 z-10">
                      ${onSale ? `<span class="inline-flex items-center font-sans text-[12px] font-bold tracking-[1.5px] uppercase px-3 py-1.5 leading-none rounded-none bg-ink text-on-dark">SALE -${discountPercent}%</span>` : ''}
                      ${!prod.stock ? `<span class="inline-flex items-center font-sans text-[11px] font-bold tracking-[1.5px] uppercase px-3 py-1.5 leading-none rounded-none bg-mute text-on-primary">SOLD OUT</span>` : ''}
                      ${prod.origin_country === 'thailand' ? `<span class="inline-flex items-center font-sans text-[11px] font-bold tracking-[1.5px] uppercase px-3 py-1.5 leading-none rounded-none bg-accent-gold text-on-dark">THAI</span>` : ''}
                    </div>
                  </div>
                </a>
                <div class="flex flex-col flex-1 p-3.5 sm:p-5 gap-3">
                  <span class="font-sans text-[12px] md:text-[13px] font-bold tracking-[2px] uppercase text-mute">${prod.brand}</span>
                  <a href="/products/${prod.slug}" class="no-underline text-ink block flex-1">
                    <h3 class="font-sans text-[15px] md:text-[16px] font-semibold leading-[1.4] line-clamp-2 text-ink m-0">${prod.name}</h3>
                  </a>
                  <div class="flex items-baseline gap-2 mt-1">
                    <span class="font-sans text-[20px] md:text-[22px] font-bold text-ink leading-none">${formatBDT(currentPrice)}</span>
                    ${onSale ? `<span class="font-sans text-[14px] md:text-[15px] text-ash line-through">${formatBDT(originalPrice)}</span>` : ''}
                  </div>
                  <div class="mt-auto pt-4">
                    ${prod.stock ? `
                      <button class="flex items-center justify-center gap-1.5 sm:gap-2 w-full h-12 px-2 sm:px-6 bg-primary text-on-primary font-sans text-[11px] sm:text-[13px] font-bold tracking-[0.5px] sm:tracking-[1.2px] uppercase rounded-none cursor-pointer hover:bg-primary-pressed active:bg-primary-pressed transition-colors duration-150 whitespace-nowrap" data-add-to-cart data-id="${prod.id}" data-name="${prod.name}" data-price="${prod.price}" data-img="${imgUrl}">
                        <svg class="hidden sm:block" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"></path>
                          <line x1="3" y1="6" x2="21" y2="6"></line>
                          <path d="M16 10a4 4 0 01-8 0"></path>
                        </svg>
                        <span>Add to Bag</span>
                      </button>
                    ` : `
                      <span class="flex items-center justify-center w-full h-12 px-2 border border-hairline-soft font-sans text-[11px] sm:text-[13px] font-semibold text-mute uppercase rounded-none bg-surface-soft whitespace-nowrap">Out of Stock</span>
                    `}
                  </div>
                </div>
              `;
              grid.appendChild(card);
            });

            grid.classList.add('open');
          }
        } else {
          throw new Error('Fetch failed');
        }
      } catch (err) {
        console.error('Error loading tab items:', err);
        if (shimmer) shimmer.style.display = 'none';
        if (emptyState) emptyState.style.display = 'block';
      }
    }

    tabButtons.forEach((btn) => {
      btn.addEventListener('click', (e) => {
        const target = e.target as HTMLButtonElement;
        
        tabButtons.forEach((b) => {
          b.classList.remove('active');
          b.setAttribute('aria-selected', 'false');
        });

        target.classList.add('active');
        target.setAttribute('aria-selected', 'true');

        const type = target.getAttribute('data-tab-type') || 'skin-concern';
        const value = target.getAttribute('data-tab-value') || 'acne';
        
        loadTabProducts(type, value);
      });
    });

    const activeBtn = component.querySelector('.tab-btn.active') as HTMLButtonElement;
    if (activeBtn) {
      const type = activeBtn.getAttribute('data-tab-type') || 'skin-concern';
      const value = activeBtn.getAttribute('data-tab-value') || 'acne';
      loadTabProducts(type, value);
    }
  });
</script>
