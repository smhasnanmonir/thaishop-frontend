---
import ImageCard from "./ImageCard.astro";
import type { Category } from "../../lib/api";

interface Props {
  category: Category;
}

const { category } = Astro.props;
const imageUrl = category.img || "https://images.unsplash.com/photo-1512290923902-8a9f81dc236c?q=80&w=400&auto=format&fit=crop";
---

<ImageCard
  href={`/categories/${category.slug}`}
  image={imageUrl}
  alt={category.name}
  title={category.name}
  aspect="square"
/>
