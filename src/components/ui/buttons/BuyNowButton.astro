---
/**
 * BuyNowButton — Reusable "Buy Now" button.
 * Adds product to localStorage cart then redirects to /checkout.
 * All product data passed via data attributes.
 */
interface Props {
  productId: number;
  name: string;
  price: number;
  image: string;
  slug?: string;
  quantity?: number;
  fullWidth?: boolean;
  disabled?: boolean;
  stock?: boolean;
  id?: string;
}

const {
  productId,
  name,
  price,
  image,
  slug = "",
  quantity = 1,
  fullWidth = true,
  disabled = false,
  stock = true,
  id,
} = Astro.props;
---

<button
  class:list={[
    "inline-flex items-center justify-center min-h-[52px] sm:h-14 px-6 bg-ink text-on-dark rounded-none font-sans text-[13px] font-bold tracking-[1.2px] uppercase cursor-pointer transition-colors duration-200 hover:bg-primary whitespace-nowrap",
    fullWidth ? "flex-1 w-full" : "",
    disabled ? "opacity-50 cursor-not-allowed pointer-events-none" : "",
  ]}
  id={id}
  data-buy-now
  data-id={productId}
  data-name={name}
  data-price={price}
  data-img={image}
  data-slug={slug}
  data-qty={quantity}
  data-stock={stock}
  disabled={disabled || !stock}
  aria-label={`Buy ${name} now`}
>
  Buy Now
</button>

<script>
  /**
   * BuyNowButton client handler.
   * Reads product data from data attributes, adds to localStorage cart, redirects to checkout.
   */
  document.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('[data-buy-now]') as HTMLElement | null;
    if (!btn || btn.hasAttribute('disabled')) return;
    const stock = btn.getAttribute('data-stock');
    if (stock === 'false') return;
    e.preventDefault();

    const STORAGE_KEY = 'tok_cart';
    const productId = parseInt(btn.getAttribute('data-id') || '0');
    const name = btn.getAttribute('data-name') || '';
    const price = parseFloat(btn.getAttribute('data-price') || '0');
    const image = btn.getAttribute('data-img') || '';
    const slug = btn.getAttribute('data-slug') || '';
    const qty = parseInt(btn.getAttribute('data-qty') || '1');

    let items: any[] = [];
    try { items = JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]'); } catch { items = []; }

    const existing = items.find((i: any) => i.productId === productId);
    if (existing) {
      existing.quantity += qty;
    } else {
      items.push({ productId, name, price, image, slug, quantity: qty });
    }

    localStorage.setItem(STORAGE_KEY, JSON.stringify(items));

    // Update badge
    const totalItems = items.reduce((s: number, i: any) => s + i.quantity, 0);
    const badge = document.getElementById('nav-cart-count');
    const mobileBadge = document.getElementById('mobile-nav-cart-count');
    if (badge) badge.innerText = totalItems.toString();
    if (mobileBadge) mobileBadge.innerText = totalItems.toString();

    window.location.href = '/checkout';
  });
</script>
