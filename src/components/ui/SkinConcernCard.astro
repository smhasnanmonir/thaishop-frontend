---
import ImageCard from "./ImageCard.astro";
import type { SkinConcern } from "../../lib/api";

interface Props {
  concern: SkinConcern;
}

const { concern } = Astro.props;
const imageUrl = concern.img || "https://images.unsplash.com/photo-1512290923902-8a9f81dc236c?q=80&w=400&auto=format&fit=crop";
---

<ImageCard
  href={`/concerns/${concern.slug}`}
  image={imageUrl}
  alt={concern.name}
  overline="TARGET CONCERN"
  title={concern.name}
  cta="Shop Solutions"
  aspect="square"
/>
