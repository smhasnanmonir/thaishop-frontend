---
interface Props {
  url: string;
  title?: string;
  poster?: string;
}

const { url, title = "Video", poster } = Astro.props;
---

<div
  class="vp relative aspect-video bg-black overflow-hidden select-none"
  data-video-url={url}
  data-video-poster={poster || ""}
  role="button"
  tabindex="0"
  aria-label={`Play ${title}`}
>
  <!-- poster + big play button -->
  <div class="vp-poster absolute inset-0 z-10 flex items-center justify-center bg-ink/20 transition-opacity duration-300 cursor-pointer">
    {poster && (
      <img src={poster} alt="" class="absolute inset-0 w-full h-full object-cover" aria-hidden="true" />
    )}
    <div class="relative flex items-center justify-center w-16 h-16 md:w-20 md:h-20 rounded-full bg-primary text-on-primary shadow-lg transition-transform duration-200 hover:scale-110">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" class="ml-1">
        <polygon points="8,5 19,12 8,19" />
      </svg>
    </div>
  </div>

  <!-- video (hidden until poster is clicked) -->
  <video class="absolute inset-0 w-full h-full object-contain vp-video" playsinline preload="none"></video>

  <!-- controls -->
  <div class="vp-controls absolute bottom-0 left-0 right-0 z-20 bg-gradient-to-t from-black/80 via-black/40 to-transparent pt-8 pb-2 px-3 opacity-0 transition-opacity duration-300 pointer-events-none">
    <!-- progress -->
    <div class="vp-progress-wrap group/bar relative h-5 flex items-center cursor-pointer mb-1 pointer-events-auto" data-role="progress">
      <div class="w-full h-[3px] group-hover/bar:h-[5px] bg-white/20 relative transition-all">
        <div class="absolute left-0 top-0 h-full bg-primary vp-progress-fill" style="width:0%"></div>
        <div class="absolute top-1/2 -translate-y-1/2 w-3 h-3 rounded-full bg-primary shadow opacity-0 group-hover/bar:opacity-100 transition-opacity vp-progress-thumb" style="left:0%"></div>
      </div>
    </div>

    <!-- row -->
    <div class="flex items-center gap-2 text-white/90 font-sans pointer-events-auto">
      <button class="vp-play-btn flex items-center justify-center w-8 h-8 shrink-0 cursor-pointer hover:text-primary transition-colors" aria-label="Play">
        <svg class="vp-icon-play" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><polygon points="8,5 19,12 8,19" /></svg>
        <svg class="vp-icon-pause hidden" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="4" width="4" height="16" /><rect x="14" y="4" width="4" height="16" /></svg>
      </button>

      <span class="vp-time text-[11px] tracking-wide tabular-nums whitespace-nowrap opacity-80">
        <span class="vp-current">0:00</span><span class="mx-0.5">/</span><span class="vp-duration">0:00</span>
      </span>

      <div class="flex-1"></div>

      <!-- volume -->
      <div class="flex items-center gap-1">
        <button class="vp-mute-btn flex items-center justify-center w-8 h-8 shrink-0 cursor-pointer hover:text-primary transition-colors" aria-label="Mute">
          <svg class="vp-icon-vol-on" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
            <path d="M19.07 4.93a10 10 0 0 1 0 14.14"></path>
            <path d="M15.54 8.46a5 5 0 0 1 0 7.07"></path>
          </svg>
          <svg class="vp-icon-vol-off hidden" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
            <line x1="23" y1="9" x2="17" y2="15"></line>
            <line x1="17" y1="9" x2="23" y2="15"></line>
          </svg>
        </button>
        <div class="hidden sm:flex items-center group/vol w-0 group-hover/vol:w-20 overflow-hidden transition-all duration-200">
          <input type="range" min="0" max="1" step="0.05" value="1" class="vp-volume-slider w-full h-1 cursor-pointer" aria-label="Volume" />
        </div>
      </div>

      <!-- fullscreen -->
      <button class="vp-fullscreen-btn flex items-center justify-center w-8 h-8 shrink-0 cursor-pointer hover:text-primary transition-colors" aria-label="Fullscreen">
        <svg class="vp-icon-expand" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 3 21 3 21 9"></polyline>
          <polyline points="9 21 3 21 3 15"></polyline>
          <line x1="21" y1="3" x2="14" y2="10"></line>
          <line x1="3" y1="21" x2="10" y2="14"></line>
        </svg>
        <svg class="vp-icon-shrink hidden" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="4 14 10 14 10 20"></polyline>
          <polyline points="20 10 14 10 14 4"></polyline>
          <line x1="14" y1="10" x2="21" y2="3"></line>
          <line x1="3" y1="21" x2="10" y2="14"></line>
        </svg>
      </button>
    </div>
  </div>
</div>

<script>
  function fmt(s: number) {
    if (!isFinite(s)) return "0:00";
    const m = Math.floor(s / 60);
    const sec = Math.floor(s % 60);
    return `${m}:${sec < 10 ? "0" : ""}${sec}`;
  }

  document.querySelectorAll<HTMLElement>(".vp").forEach((root) => {
    const video = root.querySelector<HTMLVideoElement>(".vp-video")!;
    const poster = root.querySelector<HTMLElement>(".vp-poster")!;
    const playBtn = root.querySelector<HTMLButtonElement>(".vp-play-btn")!;
    const iconPlay = root.querySelector<HTMLElement>(".vp-icon-play")!;
    const iconPause = root.querySelector<HTMLElement>(".vp-icon-pause")!;
    const currentTime = root.querySelector<HTMLElement>(".vp-current")!;
    const durEl = root.querySelector<HTMLElement>(".vp-duration")!;
    const progressWrap = root.querySelector<HTMLElement>("[data-role='progress']")!;
    const progressFill = root.querySelector<HTMLElement>(".vp-progress-fill")!;
    const progressThumb = root.querySelector<HTMLElement>(".vp-progress-thumb")!;
    const muteBtn = root.querySelector<HTMLButtonElement>(".vp-mute-btn")!;
    const iconVolOn = root.querySelector<HTMLElement>(".vp-icon-vol-on")!;
    const iconVolOff = root.querySelector<HTMLElement>(".vp-icon-vol-off")!;
    const volumeSlider = root.querySelector<HTMLInputElement>(".vp-volume-slider")!;
    const fullscreenBtn = root.querySelector<HTMLButtonElement>(".vp-fullscreen-btn")!;
    const iconExpand = root.querySelector<HTMLElement>(".vp-icon-expand")!;
    const iconShrink = root.querySelector<HTMLElement>(".vp-icon-shrink")!;
    const controls = root.querySelector<HTMLElement>(".vp-controls")!;

    let hideTimer: ReturnType<typeof setTimeout>;

    function showControls() {
      controls.style.opacity = "1";
      controls.style.pointerEvents = "auto";
      clearTimeout(hideTimer);
      hideTimer = setTimeout(() => {
        if (!video.paused) {
          controls.style.opacity = "0";
          controls.style.pointerEvents = "none";
        }
      }, 3000);
    }

    function syncPlayIcon() {
      const paused = video.paused;
      iconPlay.classList.toggle("hidden", !paused);
      iconPause.classList.toggle("hidden", paused);
    }

    function onTimeUpdate() {
      if (!video.duration) return;
      const pct = (video.currentTime / video.duration) * 100;
      progressFill.style.width = pct + "%";
      progressThumb.style.left = pct + "%";
      currentTime.textContent = fmt(video.currentTime);
    }

    function seek(e: MouseEvent) {
      const rect = progressWrap.getBoundingClientRect();
      const pct = Math.max(0, Math.min(1, (e.clientX - rect.left) / rect.width));
      video.currentTime = pct * video.duration;
    }

    // click poster → set source + start
    function loadAndPlay() {
      if (!video.src) {
        video.src = root.getAttribute("data-video-url") || "";
        video.load();
      }
      video.play().catch(() => {});
    }

    poster.addEventListener("click", () => {
      poster.style.opacity = "0";
      poster.style.pointerEvents = "none";
      loadAndPlay();
    });

    // play / pause
    playBtn.addEventListener("click", (e) => {
      e.stopPropagation();
      if (video.paused) video.play(); else video.pause();
    });

    video.addEventListener("click", () => {
      if (video.paused) video.play(); else video.pause();
    });

    root.addEventListener("keydown", (e) => {
      if (e.key === "Enter" || e.key === " ") { e.preventDefault(); if (video.paused) video.play(); else video.pause(); }
    });

    video.addEventListener("play", syncPlayIcon);
    video.addEventListener("pause", syncPlayIcon);
    video.addEventListener("timeupdate", onTimeUpdate);
    video.addEventListener("loadedmetadata", () => { durEl.textContent = fmt(video.duration); });

    // seek
    let seeking = false;
    progressWrap.addEventListener("mousedown", (e) => { seeking = true; seek(e); });
    document.addEventListener("mousemove", (e) => { if (seeking) seek(e); });
    document.addEventListener("mouseup", () => { seeking = false; });

    // mute
    muteBtn.addEventListener("click", (e) => {
      e.stopPropagation();
      video.muted = !video.muted;
      iconVolOn.classList.toggle("hidden", video.muted);
      iconVolOff.classList.toggle("hidden", !video.muted);
    });

    // volume slider
    volumeSlider.addEventListener("input", (e) => {
      e.stopPropagation();
      video.volume = parseFloat(volumeSlider.value);
      if (video.volume === 0) { video.muted = true; } else { video.muted = false; iconVolOn.classList.remove("hidden"); iconVolOff.classList.add("hidden"); }
    });

    // fullscreen
    fullscreenBtn.addEventListener("click", (e) => {
      e.stopPropagation();
      if (document.fullscreenElement) document.exitFullscreen(); else root.requestFullscreen();
    });
    document.addEventListener("fullscreenchange", () => {
      const fs = !!document.fullscreenElement;
      iconExpand.classList.toggle("hidden", fs);
      iconShrink.classList.toggle("hidden", !fs);
    });

    // auto-hide
    root.addEventListener("mousemove", showControls);
    root.addEventListener("mouseleave", () => { if (!video.paused) { controls.style.opacity = "0"; controls.style.pointerEvents = "none"; } });
    video.addEventListener("play", showControls);
    video.addEventListener("pause", () => { controls.style.opacity = "1"; controls.style.pointerEvents = "auto"; clearTimeout(hideTimer); });
  });
</script>

<style>
  .vp-video::-webkit-media-controls { display: none !important; }
  .vp-video::-webkit-media-controls-enclosure { display: none !important; }
  .vp-volume-slider {
    -webkit-appearance: none;
    appearance: none;
    height: 4px;
    background: rgba(255,255,255,0.25);
    border-radius: 0;
    outline: none;
  }
  .vp-volume-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 10px; height: 10px;
    background: var(--color-primary);
    border-radius: 0;
    cursor: pointer;
  }
  .vp-volume-slider::-moz-range-thumb {
    width: 10px; height: 10px;
    background: var(--color-primary);
    border: none; border-radius: 0;
    cursor: pointer;
  }
</style>
