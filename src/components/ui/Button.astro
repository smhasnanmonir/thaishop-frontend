---
interface Props {
  variant?: "primary" | "secondary" | "ghost" | "outline";
  size?: "md" | "sm" | "lg";
  href?: string;
  class?: string;
  type?: "button" | "submit" | "reset";
  id?: string;
  fullWidth?: boolean;
  [key: string]: any;
}

const {
  variant = "primary",
  size = "md",
  href,
  class: className = "",
  type = "button",
  id,
  fullWidth = false,
  ...rest
} = Astro.props;

const sizeClasses = {
  sm: "h-10 px-5 py-2 text-[12px] tracking-[1.2px]",
  md: "h-12 px-7 py-3 text-[13px] tracking-[1.2px]",
  lg: "h-14 px-8 py-3 text-[13px] tracking-[1.2px]",
};

const variantClasses = {
  primary: "bg-primary text-on-primary border border-primary hover:bg-primary-pressed hover:border-primary-pressed active:bg-primary-pressed",
  secondary: "bg-transparent text-ink border-2 border-ink hover:bg-surface-blush active:bg-surface-blush",
  ghost: "bg-transparent text-mute hover:text-ink hover:bg-ink/5 active:bg-ink/5",
  outline: "bg-transparent text-primary border-2 border-primary hover:bg-primary hover:text-on-primary active:bg-primary",
};

const baseClasses = [
  "inline-flex items-center justify-center",
  "font-sans font-bold uppercase",
  "rounded-none cursor-pointer",
  "transition-all duration-150",
  "whitespace-nowrap no-underline",
  sizeClasses[size],
  variantClasses[variant],
  fullWidth ? "w-full" : "",
  className,
].join(" ");
---

{
  href ? (
    <a href={href} class={baseClasses} id={id} {...rest}>
      <slot />
    </a>
  ) : (
    <button type={type} class={baseClasses} id={id} {...rest}>
      <slot />
    </button>
  )
}
