---
import { formatPrice } from "../../lib/utils";
import type { Product } from "../../lib/api";

interface Props {
  product: Product;
  loading?: "lazy" | "eager";
}

const { product, loading = "lazy" } = Astro.props;

const currentPrice = parseFloat(product.price);
const originalPrice = parseFloat(product.origin_price);
const onSale = originalPrice > currentPrice;
const discountPercent = onSale
  ? Math.round(((originalPrice - currentPrice) / originalPrice) * 100)
  : 0;

const imageUrl =
  product.card_photo ||
  product.img ||
  "https://images.unsplash.com/photo-1608248597279-f99d160bfcbc?q=80&w=400&auto=format&fit=crop";
---

<div
  class="group flex flex-col bg-white border border-hairline-soft rounded-none"
  data-id={product.id}
>
  {/* Image Section */}
  <a href={`/products/${product.slug}`} class="block relative" aria-label={`View details for ${product.name}`}>
    <div class="relative w-full aspect-square sm:aspect-[3/4] bg-surface-card overflow-hidden">
      <img
        src={imageUrl}
        alt={product.name}
        loading={loading}
        class="absolute inset-0 w-full h-full object-cover"
      />

      {/* Badges */}
      <div class="absolute top-3 left-3 flex flex-col gap-1.5 z-10">
        {onSale && (
          <span class="inline-flex items-center font-sans text-[12px] font-bold tracking-[1.5px] uppercase px-3 py-1.5 leading-none rounded-none bg-ink text-on-dark">
            SALE -{discountPercent}%
          </span>
        )}
        {!product.stock && (
          <span class="inline-flex items-center font-sans text-[11px] font-bold tracking-[1.5px] uppercase px-3 py-1.5 leading-none rounded-none bg-mute text-on-primary">
            SOLD OUT
          </span>
        )}
        {product.origin_country === "thailand" && (
          <span class="inline-flex items-center font-sans text-[11px] font-bold tracking-[1.5px] uppercase px-3 py-1.5 leading-none rounded-none bg-accent-gold text-on-dark">
            THAI
          </span>
        )}
      </div>
    </div>
  </a>

  {/* Content Section */}
  <div class="flex flex-col flex-1 p-3.5 sm:p-5 gap-3">
    {/* Brand */}
    <span class="font-sans text-[12px] md:text-[13px] font-bold tracking-[2px] uppercase text-mute">
      {product.brand}
    </span>

    {/* Product Name */}
    <a href={`/products/${product.slug}`} class="no-underline text-ink block flex-1">
      <h3 class="font-sans text-[15px] md:text-[16px] font-semibold leading-[1.4] line-clamp-2 text-ink m-0">
        {product.name}
      </h3>
    </a>

    {/* Price */}
    <div class="flex items-baseline gap-2 mt-1">
      <span class="font-sans text-[20px] md:text-[22px] font-bold text-ink leading-none">
        {formatPrice(product.price)}
      </span>
      {onSale && (
        <span class="font-sans text-[14px] md:text-[15px] text-ash line-through">
          {formatPrice(product.origin_price)}
        </span>
      )}
    </div>

    {/* Add to Bag Button */}
    <div class="mt-auto pt-4">
      {product.stock ? (
        <button
          class="flex items-center justify-center gap-1.5 sm:gap-2 w-full h-12 px-2 sm:px-6 bg-primary text-on-primary font-sans text-[11px] sm:text-[13px] font-bold tracking-[0.5px] sm:tracking-[1.2px] uppercase rounded-none cursor-pointer hover:bg-primary-pressed active:bg-primary-pressed transition-colors duration-150 whitespace-nowrap"
          data-add-to-cart
          data-id={product.id}
          data-name={product.name}
          data-price={product.price}
          data-img={imageUrl}
          aria-label={`Add ${product.name} to bag`}
        >
          <svg class="hidden sm:block" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"></path>
            <line x1="3" y1="6" x2="21" y2="6"></line>
            <path d="M16 10a4 4 0 01-8 0"></path>
          </svg>
          <span>Add to Bag</span>
        </button>
      ) : (
        <span class="flex items-center justify-center w-full h-12 px-2 border border-hairline-soft font-sans text-[11px] sm:text-[13px] font-semibold text-mute uppercase rounded-none bg-surface-soft whitespace-nowrap">
          Out of Stock
        </span>
      )}
    </div>
  </div>
</div>
