---
import ImageCard from "./ImageCard.astro";
import type { SkinType } from "../../lib/api";

interface Props {
  type: SkinType;
}

const { type } = Astro.props;
const imageUrl = type.img || "https://images.unsplash.com/photo-1512290923902-8a9f81dc236c?q=80&w=400&auto=format&fit=crop";
---

<ImageCard
  href={`/skin-types/${type.slug}`}
  image={imageUrl}
  alt={type.name}
  overline="SKIN TYPE"
  title={type.name}
  cta="Shop Routine"
  aspect="square"
/>
