---
/**
 * Pagination — Reusable page navigation following Petal DESIGN.md.
 * Zero border-radius, DM Sans buttons, hairline borders, primary accent for current.
 * All styles via Tailwind — no scoped <style> so client-side re-renders work.
 */
interface Props {
  currentPage: number;
  totalPages: number;
  id?: string;
}

const { currentPage, totalPages, id } = Astro.props;

function buildPages(current: number, total: number): (number | "...")[] {
  if (total <= 7) return Array.from({ length: total }, (_, i) => i + 1);
  const pages: (number | "...")[] = [1];
  if (current > 3) pages.push("...");
  for (let i = Math.max(2, current - 1); i <= Math.min(total - 1, current + 1); i++) {
    pages.push(i);
  }
  if (current < total - 2) pages.push("...");
  pages.push(total);
  return pages;
}

const pages = buildPages(currentPage, totalPages);

const btnBase = "inline-flex items-center justify-center min-w-[40px] h-10 px-2.5 border border-hairline rounded-none bg-canvas text-ink font-sans text-[14px] font-semibold no-underline transition-colors select-none";
const btnHover = "hover:bg-surface-blush hover:border-ink";
const btnActive = "bg-ink text-on-dark border-ink cursor-default font-bold";
const btnDisabled = "opacity-35 cursor-not-allowed pointer-events-none";
const navBase = "gap-1 px-3.5 text-[12px] font-bold tracking-[1px] uppercase";

// Preserve any current query params (e.g. filters, search terms) when changing pages.
const baseParams = new URLSearchParams(Astro.url.searchParams);
function pageHref(pageNum: number) {
  const params = new URLSearchParams(baseParams);
  params.set("page", String(pageNum));
  return "?" + params.toString();
}
---

<nav aria-label="Pagination" id={id} class="flex items-center gap-1.5 flex-wrap justify-center font-sans" data-current-page={currentPage} data-total-pages={totalPages}>
  {/* Prev */}
  {currentPage > 1 ? (
    <a href={pageHref(currentPage - 1)} aria-label="Previous page" class:list={[btnBase, btnHover, navBase, "gap-1"]}>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="shrink-0"><polyline points="15 18 9 12 15 6"></polyline></svg>
      <span class="hidden sm:inline">Prev</span>
    </a>
  ) : (
    <span class:list={[btnBase, btnDisabled, navBase, "gap-1"]}>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="shrink-0"><polyline points="15 18 9 12 15 6"></polyline></svg>
      <span class="hidden sm:inline">Prev</span>
    </span>
  )}

  {/* Page Numbers */}
  {pages.map((p) =>
    p === "..." ? (
      <span class="inline-flex items-center justify-center min-w-[32px] h-10 text-mute text-[14px]" aria-hidden="true">&hellip;</span>
    ) : p === currentPage ? (
      <span class:list={[btnBase, btnActive]} aria-current="page">{p}</span>
    ) : (
      <a href={pageHref(p as number)} aria-label={`Page ${p}`} class:list={[btnBase, btnHover, "font-semibold"]}>{p}</a>
    )
  )}

  {/* Next */}
  {currentPage < totalPages ? (
    <a href={pageHref(currentPage + 1)} aria-label="Next page" class:list={[btnBase, btnHover, navBase, "gap-1"]}>
      <span class="hidden sm:inline">Next</span>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="shrink-0"><polyline points="9 18 15 12 9 6"></polyline></svg>
    </a>
  ) : (
    <span class:list={[btnBase, btnDisabled, navBase, "gap-1"]}>
      <span class="hidden sm:inline">Next</span>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="shrink-0"><polyline points="9 18 15 12 9 6"></polyline></svg>
    </span>
  )}
</nav>
