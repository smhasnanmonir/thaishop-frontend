---
import MarqueeBanner from "../components/navigation/MarqueeBanner.astro";
import PrimaryNav from "../components/navigation/PrimaryNav.astro";
import Footer from "../components/navigation/Footer.astro";
import CartDrawer from "../components/features/CartDrawer.astro";
import SearchOverlay from "../components/features/SearchOverlay.astro";
import SuccessModal from "../components/ui/SuccessModal.astro";
import { MetaTags, OpenGraph, OrganizationSchema } from "../components/seo";
import Beacon from "../components/analytics/Beacon.astro";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: "website" | "article" | "product";
  noindex?: boolean;
}

const {
  title = "TOK Skincare | Authentic Thai Beauty & Skincare in Bangladesh",
  description = "Shop original Thailand skincare and beauty products in Bangladesh. Discover authentic Thai cleansers, serums, sunscreens, and moisturisers tailored for your skin.",
  image = "/og/default-og.jpg",
  type = "website",
  noindex = false,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, "https://tokbd.com").toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <MetaTags title={title} description={description} canonicalUrl={canonicalUrl} noindex={noindex} />
    <OpenGraph title={title} description={description} image={image} type={type} canonicalUrl={canonicalUrl} />
    <OrganizationSchema />

    <!-- Google Fonts Preconnect and Load -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400&family=DM+Sans:ital,wght@0,400;0,500;0,700;1,400&display=swap"
      rel="stylesheet"
    />

    <!-- Global Stylesheet loaded via Vite -->
    <slot name="head" />
  </head>
  <body>
    <MarqueeBanner />
    <PrimaryNav />
    <SearchOverlay />

    <main>
      <slot />
    </main>

    <Footer />
    <CartDrawer />
    <SuccessModal />

    <Beacon />

    <!-- Global Offline Cart Controller -->
    <script>
      import { getCount, addItem, notifyChange } from "../lib/cart";

      function initGlobalCart() {
        function readCount(): number {
          return getCount();
        }

        function emitUpdate() {
          notifyChange();
        }

        function openDrawer() {
          window.dispatchEvent(new CustomEvent("toggle-cart-drawer", { detail: { open: true } }));
        }

        function showSuccess(name: string, price: number, image: string) {
          window.dispatchEvent(
            new CustomEvent("add-to-cart-success", {
              detail: {
                name,
                price:
                  price > 0
                    ? "৳" +
                      price.toLocaleString("en-US", { minimumFractionDigits: 0, maximumFractionDigits: 0 })
                    : "৳0",
                image,
              },
            })
          );
        }

        // Public helper used by the BuyNowButton
        (window as any).updateCartBadgeCount = (count: number) => {
          const badge = document.getElementById("nav-cart-count");
          const mobileBadge = document.getElementById("mobile-nav-cart-count");
          if (badge) badge.innerText = String(count);
          if (mobileBadge) mobileBadge.innerText = String(count);
        };

        // Listen for "add-to-cart-action" from any caller
        window.addEventListener("add-to-cart-action", (e: Event) => {
          const detail = (e as CustomEvent).detail || {};
          const productId = parseInt(detail.productId);
          const quantity = parseInt(detail.quantity) || 1;
          if (Number.isNaN(productId)) return;
          if (detail.stock === false) return;

          addItem({
            productId,
            name: detail.name || "",
            price: parseFloat(detail.price) || 0,
            image: detail.image || "",
            slug: detail.slug || "",
            quantity,
          });
          emitUpdate();
          openDrawer();
          showSuccess(detail.name || "", parseFloat(detail.price) || 0, detail.image || "");
        });

          // Delegate click for any [data-add-to-cart] button
          document.addEventListener("click", (e: Event) => {
            const btn = (e.target as HTMLElement).closest<HTMLElement>("[data-add-to-cart]");
            if (!btn) return;
            e.preventDefault();
            const productId = btn.getAttribute("data-id");
            if (!productId) return;
            const stock = btn.getAttribute("data-stock");
            if (stock === "false") return;
            window.dispatchEvent(
            new CustomEvent("add-to-cart-action", {
              detail: {
                productId,
                name: btn.getAttribute("data-name") || "",
                price: btn.getAttribute("data-price") || "0",
                image: btn.getAttribute("data-img") || "",
                slug: btn.getAttribute("data-slug") || "",
                quantity: 1,
              },
            })
          );
          openDrawer();
        });

        // Initial state on load
        document.addEventListener("DOMContentLoaded", () => {
          (window as any).updateCartBadgeCount(readCount());
          emitUpdate();
        });
      }

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initGlobalCart);
      } else {
        initGlobalCart();
      }
    </script>
  </body>
</html>

<style is:global>
  html,
  body {
    margin: 0;
    padding: 0;
    width: 100%;
    min-height: 100%;
    display: flex;
    flex-direction: column;
    overflow-y: scroll;
    scrollbar-gutter: stable;
  }

  main {
    flex-grow: 1;
    width: 100%;
  }
</style>
