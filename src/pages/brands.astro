---
export const prerender = true;
import BaseLayout from "../layouts/BaseLayout.astro";
import ImageCard from "../components/ui/ImageCard.astro";
import { api } from "../lib/api";

import type { Brand } from "../lib/api";

let brands: Brand[] = [];
try {
  const homeData = await api.getHomeContent();
  brands = homeData.brands || [];
} catch (error) {
  console.error("Failed to load brands list:", error);
}
---

<BaseLayout
  title="Thai Skincare Brands | TOK Skincare Bangladesh"
  description="Explore original Thailand beauty and skincare brands imported to Bangladesh."
>
  <div class="min-h-screen">
    <div class="mx-auto px-4 md:px-6 py-12 md:py-16" style="max-width: 1536px;">
      {/* Page Header */}
      <div class="flex flex-col items-center text-center gap-2.5 mb-12 md:mb-16 max-w-2xl mx-auto">
        <div class="font-sans text-[11px] font-bold tracking-[1.5px] uppercase text-mute/70 flex items-center gap-1.5 mb-1.5">
          <a href="/" class="hover:text-primary transition-colors no-underline text-mute">Home</a>
          <span class="text-stone">&bull;</span>
          <span class="text-ink font-semibold">Brands</span>
        </div>

        <span class="font-sans text-[12px] font-bold tracking-[2.5px] uppercase text-primary leading-none">AUTHENTIC SELECTION</span>
        <h1 class="font-serif text-[34px] md:text-[44px] lg:text-[48px] font-bold text-ink leading-tight m-0">Featured Thai Brands</h1>
        <p class="font-sans text-sm md:text-base text-mute m-0 mt-2  leading-relaxed">
          Discover Thailand's leading skincare brands imported directly from pharmacy distributors in Bangkok.
        </p>
      </div>

      {/* Brands Grid */}
      {brands.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
          {brands.map((br) => (
            <ImageCard
              href={`/brands/${br.slug}`}
              image={br.img || "https://images.unsplash.com/photo-1556228720-195a672e8a03?q=80&w=400&auto=format&fit=crop"}
              alt={br.name}
              overline="THAI BRAND"
              title={br.name}
              cta="Explore Products"
              aspect="wide"
            />
          ))}
        </div>
      ) : (
        <div class="text-center py-20">
          <p class="font-sans text-base text-mute m-0">Loading brands...</p>
        </div>
      )}
    </div>
  </div>
</BaseLayout>
