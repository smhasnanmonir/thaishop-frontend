---
export const prerender = true;
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Your Shopping Bag | TOK Skincare Bangladesh"
  description="Manage items in your shopping cart before completing checkout."
>
  <div class="min-h-screen bg-canvas">
    <div class="max-w-[1100px] mx-auto px-4 md:px-6 py-12 md:py-16">
      {/* Breadcrumb */}
      <div class="font-sans text-[12px] tracking-[0.5px] text-mute mb-8 flex items-center gap-1.5">
        <a href="/" class="hover:text-primary transition-colors no-underline text-mute">Home</a>
        <span class="text-stone">&bull;</span>
        <span class="text-ink font-semibold">Shopping Bag</span>
      </div>

      {/* Page Heading */}
      <h1 class="font-serif text-[34px] md:text-[44px] lg:text-[48px] font-bold text-ink leading-tight m-0 mb-10 md:mb-14">
        Shopping Bag
      </h1>

      {/* ═══ Cart Content (shown when items exist) ═══ */}
      <div class="hidden grid grid-cols-1 lg:grid-cols-3 gap-8" id="cart-main-layout">

        {/* ── Items Column ── */}
        <div class="lg:col-span-2 flex flex-col gap-6" id="cart-items-wrapper">
          <!-- Rendered client-side -->
        </div>

        {/* ── Summary Column ── */}
        <div class="lg:col-span-1">
          <div class="bg-canvas border border-hairline p-6 md:p-8 flex flex-col gap-5 h-fit sticky top-24">
            <h3 class="font-sans text-[11px] font-bold tracking-[2px] uppercase text-ink m-0">Order Summary</h3>

            <div class="flex flex-col gap-3 border-b border-hairline-soft pb-5">
              <div class="flex justify-between font-sans text-[15px] text-body">
                <span>Items Subtotal</span>
                <span class="font-sans text-[18px] font-semibold text-ink" id="cart-summary-subtotal">৳0</span>
              </div>
              <div class="flex justify-between font-sans text-[15px] text-body">
                <span>Estimated Shipping</span>
                <span class="font-sans font-semibold text-mute text-[13px]">Calculated at Checkout</span>
              </div>
            </div>

            <div class="flex justify-between items-baseline">
              <span class="font-sans text-[18px] font-bold text-ink">Estimated Total</span>
              <span class="font-sans text-[26px] font-bold text-primary leading-none" id="cart-summary-total">৳0</span>
            </div>

            <a
              href="/checkout"
              class="flex items-center justify-center bg-primary text-on-primary font-sans text-[13px] font-bold tracking-[1.2px] uppercase h-12 rounded-none no-underline transition-colors duration-150 hover:bg-primary-pressed cursor-pointer"
            >
              Proceed to Checkout
            </a>

            <a
              href="/products"
              class="font-sans text-[11px] font-bold tracking-[1px] text-mute uppercase text-center py-2 no-underline"
            >
              &larr; Continue Shopping
            </a>
          </div>
        </div>
      </div>

      {/* ═══ Empty State ═══ */}
      <div class="flex flex-col items-center justify-center py-20 text-center gap-6 border border-dashed border-hairline" id="cart-empty-panel">
        <div class="text-stone">
          <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
            <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
            <line x1="3" y1="6" x2="21" y2="6"></line>
            <path d="M16 10a4 4 0 0 1-8 0"></path>
          </svg>
        </div>
        <div class="flex flex-col gap-2 max-w-[420px]">
          <h2 class="font-serif text-heading-xl text-ink font-bold m-0">Your Bag is Empty</h2>
          <p class="font-sans text-[15px] text-mute leading-relaxed m-0">You haven't added any skincare items yet. Explore our premium selection imported directly from Bangkok.</p>
        </div>
        <a
          href="/products"
          class="inline-flex items-center justify-center bg-primary text-on-primary font-sans text-[13px] font-bold tracking-[1.2px] uppercase h-12 px-8 rounded-none no-underline transition-colors duration-150 hover:bg-primary-pressed"
        >
          Start Shopping
        </a>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  import { getItems, updateQty, removeItem } from "../lib/cart";

  function formatBDT(val: number) {
    return "৳" + val.toLocaleString("en-US", { minimumFractionDigits: 0, maximumFractionDigits: 0 });
  }

  function escapeAttr(value: string): string {
    return String(value || "")
      .replace(/&/g, "&amp;")
      .replace(/"/g, "&quot;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;");
  }

  function initCartPage() {
    const mainLayout = document.getElementById("cart-main-layout");
    const emptyPanel = document.getElementById("cart-empty-panel");
    const itemsWrapper = document.getElementById("cart-items-wrapper");
    const subtotalText = document.getElementById("cart-summary-subtotal");
    const totalText = document.getElementById("cart-summary-total");

    function render(items: ReturnType<typeof getItems>) {
      if (items.length === 0) {
        if (mainLayout) mainLayout.classList.add("hidden");
        if (emptyPanel) emptyPanel.classList.remove("hidden");
        if (itemsWrapper) itemsWrapper.innerHTML = "";
        return;
      }

      if (mainLayout) mainLayout.classList.remove("hidden");
      if (emptyPanel) emptyPanel.classList.add("hidden");

      if (!itemsWrapper) return;
      itemsWrapper.innerHTML = "";
      let subtotal = 0;

      items.forEach((item) => {
        subtotal += item.price * item.quantity;

        const card = document.createElement("div");
        card.className = "flex flex-col sm:flex-row gap-5 p-5 bg-canvas border border-hairline items-start sm:items-center justify-between";
        card.innerHTML = `
          <a href="/products/${escapeAttr(item.slug || String(item.productId))}" class="flex gap-4 items-center no-underline text-ink">
            <div class="w-[80px] h-[107px] shrink-0 overflow-hidden bg-surface-card border border-hairline-soft">
              <img src="${escapeAttr(item.image)}" alt="${escapeAttr(item.name)}" loading="lazy" decoding="async" class="w-full h-full object-cover" />
            </div>
            <div class="flex flex-col gap-1 min-w-0">
              <h3 class="font-sans text-[15px] font-semibold text-ink leading-snug line-clamp-2 m-0">${escapeAttr(item.name)}</h3>
              <span class="font-sans text-[18px] font-semibold text-primary">${formatBDT(item.price)}</span>
            </div>
          </a>

          <div class="flex items-center justify-between w-full sm:w-auto gap-6 sm:gap-8">
            <div class="flex items-center border border-hairline h-10 bg-surface-soft">
              <button class="w-10 h-full flex items-center justify-center font-bold text-[14px] text-ink hover:bg-secondary-bg cursor-pointer transition-colors cart-dec-btn" data-id="${item.productId}" aria-label="Decrease quantity">-</button>
              <span class="w-10 text-center font-sans text-[14px] font-bold">${item.quantity}</span>
              <button class="w-10 h-full flex items-center justify-center font-bold text-[14px] text-ink hover:bg-secondary-bg cursor-pointer transition-colors cart-inc-btn" data-id="${item.productId}" aria-label="Increase quantity">+</button>
            </div>

            <span class="font-sans text-[20px] font-semibold text-ink w-24 text-right">${formatBDT(item.price * item.quantity)}</span>

            <button class="text-mute hover:text-error cursor-pointer transition-colors cart-remove-btn" data-id="${item.productId}" aria-label="Remove item">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <polyline points="3 6 5 6 21 6"></polyline>
                <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
              </svg>
            </button>
          </div>
        `;
        itemsWrapper.appendChild(card);
      });

      if (subtotalText) subtotalText.innerText = formatBDT(subtotal);
      if (totalText) totalText.innerText = formatBDT(subtotal);
    }

    // Re-render whenever any cart mutation occurs
    window.addEventListener("cart-updated", (e: Event) => {
      const detail = (e as CustomEvent).detail;
      render(Array.isArray(detail) ? detail : getItems());
    });

    // Stepper + remove via shared store
    itemsWrapper?.addEventListener("click", (e) => {
      const btn = (e.target as HTMLElement).closest("button");
      if (!btn) return;

      const productId = parseInt(btn.getAttribute("data-id") || "");
      if (Number.isNaN(productId)) return;

      if (btn.classList.contains("cart-inc-btn")) {
        const current = getItems().find((i) => i.productId === productId);
        updateQty(productId, (current?.quantity || 0) + 1);
      } else if (btn.classList.contains("cart-dec-btn")) {
        const current = getItems().find((i) => i.productId === productId);
        if (!current) return;
        updateQty(productId, current.quantity - 1);
      } else if (btn.classList.contains("cart-remove-btn")) {
        removeItem(productId);
      }
    });

    // Initial render
    render(getItems());
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initCartPage);
  } else {
    initCartPage();
  }
</script>
