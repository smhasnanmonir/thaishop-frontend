---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Page Not Found | TOK Skincare Bangladesh"
  description="The page you're looking for doesn't exist. Browse our authentic Thai skincare collection."
>
  <div class="min-h-[70vh] flex items-center justify-center bg-canvas px-4 py-16">
    <div class="flex flex-col items-center text-center gap-8 max-w-lg">

      {/* Large 404 display */}
      <div class="relative">
        <span class="font-serif text-[120px] md:text-[160px] font-bold text-surface-blush leading-none select-none">404</span>
        <span class="absolute inset-0 flex items-center justify-center font-serif text-[36px] md:text-[48px] font-bold text-ink leading-none">Lost?</span>
      </div>

      {/* Message */}
      <div class="flex flex-col gap-3">
        <h1 class="font-serif text-[28px] md:text-[34px] font-bold text-ink leading-tight m-0">
          Page Not Found
        </h1>
        <p class="font-sans text-[15px] md:text-[16px] text-body leading-relaxed m-0">
          The skincare page you're looking for seems to have wandered off. Let's get you back on track.
        </p>
      </div>

      {/* Action buttons */}
      <div class="flex flex-col sm:flex-row gap-3 w-full sm:w-auto">
        <a
          href="/products"
          class="inline-flex items-center justify-center bg-primary text-on-primary font-sans text-[13px] font-bold tracking-[1.2px] uppercase h-12 px-8 rounded-none no-underline transition-colors duration-150 hover:bg-primary-pressed"
        >
          Shop All Products
        </a>
        <a
          href="/"
          class="inline-flex items-center justify-center bg-transparent text-ink border-2 border-ink font-sans text-[13px] font-bold tracking-[1.2px] uppercase h-12 px-8 rounded-none no-underline transition-colors duration-150 hover:bg-surface-blush"
        >
          Back to Home
        </a>
      </div>

      {/* Quick links */}
      <div class="border-t border-hairline pt-8 w-full">
        <p class="font-sans text-[11px] font-bold tracking-[2px] uppercase text-stone mb-5">Or explore</p>
        <div class="flex flex-wrap justify-center gap-3">
          <a href="/categories" class="inline-flex items-center gap-2 border border-hairline bg-surface-card px-5 py-2.5 font-sans text-[12px] font-bold tracking-[1px] uppercase text-ink no-underline hover:bg-ink hover:text-on-dark hover:border-ink transition-colors duration-200">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect></svg>
            Categories
          </a>
          <a href="/brands" class="inline-flex items-center gap-2 border border-hairline bg-surface-card px-5 py-2.5 font-sans text-[12px] font-bold tracking-[1px] uppercase text-ink no-underline hover:bg-ink hover:text-on-dark hover:border-ink transition-colors duration-200">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path><line x1="7" y1="7" x2="7.01" y2="7"></line></svg>
            Brands
          </a>
          <a href="/concerns" class="inline-flex items-center gap-2 border border-hairline bg-surface-card px-5 py-2.5 font-sans text-[12px] font-bold tracking-[1px] uppercase text-ink no-underline hover:bg-ink hover:text-on-dark hover:border-ink transition-colors duration-200">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
            Concerns
          </a>
          <a href="/skin-types" class="inline-flex items-center gap-2 border border-hairline bg-surface-card px-5 py-2.5 font-sans text-[12px] font-bold tracking-[1px] uppercase text-ink no-underline hover:bg-ink hover:text-on-dark hover:border-ink transition-colors duration-200">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
            Skin Types
          </a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
