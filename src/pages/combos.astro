---
export const prerender = false;
import BaseLayout from "../layouts/BaseLayout.astro";
import ComboCard from "../components/ui/ComboCard.astro";
import { BreadcrumbSchema } from "../components/seo";
import { api } from "../lib/api";
import type { ComboListItem } from "../lib/api";

const PAGE_SIZE = 100;

let combos: ComboListItem[] = [];
let total = 0;

try {
  const data = await api.getAllCombos(1, PAGE_SIZE);
  combos = data.result || [];
  total = data.total || 0;
} catch (error) {
  console.error("Failed to load combos list:", error);
}
---

<BaseLayout
  title="Skincare Bundles & Combos | TOK Skincare Bangladesh"
  description="Shop curated Thai skincare bundles and value combos. Save on authentic serums, moisturisers, sunscreens, and cleansers — perfectly paired for your routine."
>
  <Fragment slot="head">
    <BreadcrumbSchema
      items={[
        { label: "Home", href: "/" },
        { label: "Combos" },
      ]}
    />
  </Fragment>

  <div class="min-h-screen bg-canvas">
    <div class="mx-auto px-4 md:px-6 py-12 md:py-16" style="max-width: 1536px;">
      {/* Page Header */}
      <div class="flex flex-col items-center text-center gap-2.5 mb-12 md:mb-16 max-w-2xl mx-auto">
        <div class="font-sans text-[11px] font-bold tracking-[1.5px] uppercase text-mute/70 flex items-center gap-1.5 mb-1.5">
          <a href="/" class="hover:text-primary transition-colors no-underline text-mute">Home</a>
          <span class="text-stone">&bull;</span>
          <span class="text-ink font-semibold">Combos</span>
        </div>

        <span class="font-sans text-[12px] font-bold tracking-[2.5px] uppercase text-primary leading-none">CURATED BUNDLES</span>
        <h1 class="font-serif text-[34px] md:text-[44px] lg:text-[48px] font-bold text-ink leading-tight m-0">Value Combos</h1>
        <p class="font-sans text-sm md:text-base text-mute m-0 mt-2 leading-relaxed">
          Curated Thai skincare bundles — perfectly paired products at exclusive prices. Save while building your ritual.
        </p>
        {total > 0 && (
          <p class="font-sans text-[13px] text-mute/70 m-0 mt-1">
            {total} combo{total !== 1 ? "s" : ""} available
          </p>
        )}
      </div>

      {/* Combos Grid */}
      {combos.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5 sm:gap-6">
          {combos.map((combo) => (
            <ComboCard combo={combo} />
          ))}
        </div>
      ) : (
        <div class="flex flex-col items-center justify-center py-20 text-center gap-6 border border-dashed border-hairline">
          <div class="text-stone">
            <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="18" height="18" rx="0" ry="0"></rect>
              <line x1="3" y1="9" x2="21" y2="9"></line>
              <line x1="9" y1="3" x2="9" y2="21"></line>
            </svg>
          </div>
          <div class="flex flex-col gap-2 max-w-[400px]">
            <h2 class="font-serif text-[28px] text-ink font-bold m-0">No Bundles Yet</h2>
            <p class="font-sans text-[15px] text-mute leading-relaxed m-0">We're curating the perfect skincare bundles. Check back soon or browse our full collection.</p>
          </div>
          <a href="/products" class="inline-flex items-center justify-center bg-primary text-on-primary font-sans text-[13px] font-bold tracking-[1.2px] uppercase h-12 px-8 rounded-none no-underline transition-colors duration-150 hover:bg-primary-pressed">
            Shop All Products
          </a>
        </div>
      )}
    </div>
  </div>
</BaseLayout>
