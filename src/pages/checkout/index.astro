---
export const prerender = true;
import CheckoutLayout from "../../layouts/CheckoutLayout.astro";
---

<CheckoutLayout title="Secure Checkout | TOK Skincare">
  <!-- Empty State -->
  <div id="checkout-empty-state" class="hidden">
    <div class="flex flex-col items-center justify-center py-20 text-center gap-6 border border-dashed border-hairline">
      <div class="text-stone">
        <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 01-8 0"></path></svg>
      </div>
      <div class="flex flex-col gap-2 max-w-[400px]">
        <h2 class="font-serif text-heading-xl text-ink font-bold m-0">No Products to Checkout</h2>
        <p class="font-sans text-[15px] text-mute leading-relaxed m-0">Your bag is empty. Add some products to continue.</p>
      </div>
      <div class="flex flex-col sm:flex-row gap-3">
        <a href="/products" class="inline-flex items-center justify-center bg-primary text-on-primary font-sans text-[13px] font-bold tracking-[1.2px] uppercase h-12 px-8 rounded-none no-underline transition-colors duration-150 hover:bg-primary-pressed">Continue Shopping</a>
        <a href="/" class="inline-flex items-center justify-center bg-transparent text-ink border border-hairline font-sans text-[13px] font-bold tracking-[1.2px] uppercase h-12 px-8 rounded-none no-underline transition-colors duration-150 hover:bg-surface-blush">Back to Home</a>
      </div>
    </div>
  </div>

  <!-- Main Checkout Screen -->
  <div id="checkout-main-screen" class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
    
    <!-- Billing/Shipping Form Column -->
    <div class="lg:col-span-7 flex flex-col gap-6">
      <div class="bg-canvas border border-hairline p-6 rounded-none">
        <h2 class="font-serif text-heading-xl text-ink mb-6">Delivery Address</h2>
        
        <form id="checkout-form" class="flex flex-col gap-4">
          <!-- Full Name -->
          <div class="flex flex-col gap-1">
            <label for="bill-name" class="font-sans text-body-sm font-semibold text-ink">Full Name <span class="text-primary">*</span></label>
            <input type="text" id="bill-name" required class="bg-canvas border border-stone text-ink px-4 py-3 h-12 rounded-none text-[14px] focus:border-ink outline-none" placeholder="e.g. Monir Hasnan" />
          </div>

          <!-- Phone Number -->
          <div class="flex flex-col gap-1">
            <label for="bill-phone" class="font-sans text-body-sm font-semibold text-ink">Phone Number <span class="text-primary">*</span></label>
            <input type="tel" id="bill-phone" required pattern="^01[3-9]\d{8}$" class="bg-canvas border border-stone text-ink px-4 py-3 h-12 rounded-none text-[14px] focus:border-ink outline-none" placeholder="e.g. 01712345678" />
            <span class="font-sans text-[11px] text-mute">Used for delivery verification call (e.g. 017xxxxxxxx)</span>
          </div>

          <!-- Email -->
          <div class="flex flex-col gap-1">
            <label for="bill-email" class="font-sans text-body-sm font-semibold text-ink">Email Address <span class="text-mute">(Optional)</span></label>
            <input type="email" id="bill-email" class="bg-canvas border border-stone text-ink px-4 py-3 h-12 rounded-none text-[14px] focus:border-ink outline-none" placeholder="e.g. monir@example.com" />
          </div>

          <!-- Location (inside vs outside Dhaka) -->
          <div class="flex flex-col gap-2">
            <span class="font-sans text-[15px] font-bold text-ink">Delivery Location <span class="text-primary">*</span></span>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <label class="border border-stone p-4 flex items-center gap-3 cursor-pointer select-none bg-canvas hover:bg-surface-soft">
                <input type="radio" name="deliveryLocation" value="inside" checked class="accent-primary" />
                <div class="flex flex-col gap-1">
                  <span class="font-sans text-[15px] font-bold text-ink">Inside Dhaka</span>
                  <span class="font-sans text-[14px] font-semibold text-mute">Fee: ৳80 &bull; 2-3 Days</span>
                </div>
              </label>

              <label class="border border-stone p-4 flex items-center gap-3 cursor-pointer select-none bg-canvas hover:bg-surface-soft">
                <input type="radio" name="deliveryLocation" value="outside" class="accent-primary" />
                <div class="flex flex-col gap-1">
                  <span class="font-sans text-[15px] font-bold text-ink">Outside Dhaka</span>
                  <span class="font-sans text-[14px] font-semibold text-mute">Fee: ৳130 &bull; 3-5 Days</span>
                </div>
              </label>
            </div>
          </div>

          <!-- Detailed Address -->
          <div class="flex flex-col gap-1">
            <label for="bill-address" class="font-sans text-body-sm font-semibold text-ink">Detailed Address <span class="text-primary">*</span></label>
            <textarea id="bill-address" required class="bg-canvas border border-stone text-ink p-4 min-h-[96px] rounded-none text-[14px] focus:border-ink outline-none resize-y" placeholder="House no, Flat no, Road, Area, Landmark..."></textarea>
          </div>

          <!-- District / City -->
          <div class="flex flex-col gap-1">
            <label for="bill-city" class="font-sans text-body-sm font-semibold text-ink">District / City <span class="text-primary">*</span></label>
            <input type="text" id="bill-city" required class="bg-canvas border border-stone text-ink px-4 py-3 h-12 rounded-none text-[14px] focus:border-ink outline-none" placeholder="e.g. Dhaka" />
          </div>

          <!-- Notes -->
          <div class="flex flex-col gap-1">
            <label for="bill-notes" class="font-sans text-body-sm font-semibold text-ink">Delivery Instructions <span class="text-mute">(Optional)</span></label>
            <input type="text" id="bill-notes" class="bg-canvas border border-stone text-ink px-4 py-3 h-12 rounded-none text-[14px] focus:border-ink outline-none" placeholder="e.g. Deliver after 2 PM, call before arriving..." />
          </div>
        </form>
      </div>

      <!-- Payment Method Info -->
      <div class="bg-canvas border border-hairline p-6 rounded-none">
        <h3 class="font-serif text-heading-md text-ink mb-4">Payment Method</h3>
        <div class="border border-primary bg-surface-blush p-4 flex items-center gap-3">
          <div class="text-primary">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="2" y="5" width="20" height="14" rx="2" ry="2"></rect>
              <line x1="2" y1="10" x2="22" y2="10"></line>
            </svg>
          </div>
          <div class="flex flex-col">
            <span class="font-sans text-[13px] font-bold text-ink">Cash on Delivery (COD)</span>
            <span class="font-sans text-[12px] text-mute">Pay with cash when your package is delivered to your door.</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Summary Invoice Column -->
    <div class="lg:col-span-5 flex flex-col gap-6 sticky top-24">
      <div class="bg-canvas border border-hairline p-6 rounded-none flex flex-col gap-4">
        <h3 class="font-sans text-overline font-bold tracking-overline text-ink uppercase">Your Order Items</h3>

        <!-- Checkout list -->
        <div class="flex flex-col gap-4 max-h-[280px] overflow-y-auto pr-2" id="checkout-items-list">
          <!-- Rendered client-side -->
        </div>

        <div class="border-t border-hairline pt-4 flex flex-col gap-2">
          <div class="flex justify-between font-sans text-body-sm text-mute">
            <span>Items Subtotal:</span>
            <span class="font-sans text-[18px] font-semibold text-ink" id="checkout-subtotal">৳0</span>
          </div>
          <div class="flex justify-between font-sans text-body-sm text-mute">
            <span>Delivery Charge:</span>
            <span class="font-sans text-[18px] font-semibold text-ink" id="checkout-shipping">৳80</span>
          </div>
          <div class="border-t border-hairline-soft pt-2 mt-2 flex justify-between font-sans text-[18px] font-bold text-ink">
            <span>Total Payable:</span>
            <span class="font-sans text-[24px] font-bold text-primary" id="checkout-total">৳0</span>
          </div>
        </div>

        <button
          type="submit"
          form="checkout-form"
          class="w-full flex items-center justify-center bg-primary text-on-primary font-sans text-[13px] font-bold tracking-[1px] uppercase h-12 rounded-none cursor-pointer transition-colors duration-150 hover:bg-primary-pressed"
          id="place-order-submit-btn"
        >
          Place Order (Cash on Delivery)
        </button>

        <p class="font-sans text-[11px] text-mute text-center leading-relaxed">
          By clicking place order, you authorize delivery and confirm agreement to our terms. Direct Bangkok Skincare Import Care.
        </p>
      </div>
    </div>
  </div>
</CheckoutLayout>

<script>
  function initCheckout() {
    const checkoutForm = document.getElementById('checkout-form') as HTMLFormElement;
    const submitBtn = document.getElementById('place-order-submit-btn') as HTMLButtonElement;

    const itemsList = document.getElementById('checkout-items-list');
    const subtotalText = document.getElementById('checkout-subtotal');
    const shippingText = document.getElementById('checkout-shipping');
    const totalText = document.getElementById('checkout-total');

    let subtotal = 0;
    let shipping = 80; // Default inside Dhaka

    // Helper to format BDT prices client-side
    function formatBDT(val: number) {
      return '৳' + val.toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
    }

    // Load checkout details
    function loadCheckout() {
      const STORAGE_KEY = 'tok_cart';
      let items = [];
      try {
        const raw = localStorage.getItem(STORAGE_KEY);
        if (raw) items = JSON.parse(raw);
      } catch(e) { items = []; }

      if (items.length === 0) {
        // Show empty state instead of redirect
        const emptyState = document.getElementById('checkout-empty-state');
        const mainScreen = document.getElementById('checkout-main-screen');
        if (emptyState) emptyState.classList.remove('hidden');
        if (mainScreen) mainScreen.classList.add('hidden');
        return;
      }

      if (itemsList) {
        itemsList.innerHTML = '';
        subtotal = 0;

        items.forEach((item: any) => {
          subtotal += item.price * item.quantity;
          
          const card = document.createElement('div');
          // Tailwind CSS v4 class listings for items in invoice column
          card.className = 'flex items-center justify-between gap-3 pb-3 border-b border-hairline-soft';
          card.innerHTML = `
            <div class="flex gap-2 items-center">
              <div class="w-10 h-[53px] shrink-0 overflow-hidden bg-surface-card border border-hairline-soft">
                <img src="${item.image}" alt="${item.name}" class="w-full h-full object-cover" />
              </div>
              <div class="flex flex-col">
                <span class="font-sans text-[13px] font-semibold text-ink line-clamp-1 max-w-[200px]">${item.name}</span>
                <span class="font-sans text-[11px] text-mute">Qty: ${item.quantity} &bull; <span class="font-sans font-semibold">${formatBDT(item.price)}</span></span>
              </div>
            </div>
            <span class="font-sans text-[16px] font-semibold text-ink">${formatBDT(item.price * item.quantity)}</span>
          `;
          itemsList.appendChild(card);
        });

        updateInvoiceTotals();
      }
    }

    function updateInvoiceTotals() {
      if (subtotalText) subtotalText.innerText = formatBDT(subtotal);
      if (shippingText) shippingText.innerText = formatBDT(shipping);
      if (totalText) totalText.innerText = formatBDT(subtotal + shipping);
    }

    // Run initial load (with tiny delay to let layout inject localStorage script caching)
    setTimeout(loadCheckout, 100);

    // Listen for radio button changes to update delivery charge
    document.querySelectorAll('input[name="deliveryLocation"]').forEach((radio) => {
      radio.addEventListener('change', (e: any) => {
        const val = e.target.value;
        if (val === 'outside') {
          shipping = 130;
        } else {
          shipping = 80;
        }
        updateInvoiceTotals();
      });
    });

    // Form submission processing
    checkoutForm?.addEventListener('submit', async (e) => {
      e.preventDefault();

      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.innerText = 'Processing Order...';
      }

      const name = (document.getElementById('bill-name') as HTMLInputElement).value;
      const phone = (document.getElementById('bill-phone') as HTMLInputElement).value;
      const email = (document.getElementById('bill-email') as HTMLInputElement).value;
      const address = (document.getElementById('bill-address') as HTMLTextAreaElement).value;
      const city = (document.getElementById('bill-city') as HTMLInputElement).value;
      const note = (document.getElementById('bill-notes') as HTMLInputElement).value;

      const locationEl = document.querySelector('input[name="deliveryLocation"]:checked') as HTMLInputElement;
      const deliveryLocation = locationEl ? locationEl.value as 'inside' | 'outside' : 'inside';

      const STORAGE_KEY = 'tok_cart';
      let currentItems = [];
      try { currentItems = JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]'); } catch { currentItems = []; }

      const lineItems = currentItems.map((item: any) => ({
        productId: item.productId,
        quantity: item.quantity
      }));

      const payload = {
        guestId: window.tokGuestId,
        items,
        totalAmount: subtotal + shipping,
        deliveryCharge: shipping,
        userInfo: {
          name,
          email,
          phone,
          address,
          city,
          country: 'Bangladesh',
          deliveryLocation
        }
      };

      try {
        const res = await fetch('https://backend.tokbd.com/api/guest/place-order', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });

        if (res.ok) {
          const data = await res.json();
          const orderId = data.orderId || 'SUCCESS';

          // Clear local offline cart
          localStorage.removeItem('tok_cart');
          window.updateCartBadgeCount(0);

          // Clear cart on backend server
          fetch(`https://backend.tokbd.com/api/guest/cart/clear`, {
            method: 'DELETE',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ guestId: window.tokGuestId })
          }).catch(console.error);

          // Persist full order details for the confirmation page
          const orderSummary = {
            orderId,
            createdAt: new Date().toISOString(),
            paymentMethod: 'Cash on Delivery',
            user: {
              name,
              email,
              phone,
              address,
              city,
              notes: note,
              deliveryLocation,
            },
            items: currentItems,
            subtotal,
            shipping,
            total: subtotal + shipping,
          };
          try {
            localStorage.setItem('tok_last_order', JSON.stringify(orderSummary));
          } catch (e) {
            console.error('Failed to persist order summary:', e);
          }

          // Redirect to dedicated order confirmation page
          window.location.href = '/checkout/confirmation';
        } else {
          const errData = await res.json();
          alert(`Order Placement Error: ${errData.error || 'Failed to complete order. Please check inputs.'}`);
          if (submitBtn) {
            submitBtn.disabled = false;
            submitBtn.innerText = 'Place Order (Cash on Delivery)';
          }
        }
      } catch (err) {
        console.error('Checkout error:', err);
        alert('Connection error. Please check your internet connection.');
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.innerText = 'Place Order (Cash on Delivery)';
        }
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCheckout);
  } else {
    initCheckout();
  }
</script>
