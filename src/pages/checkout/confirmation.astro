---
export const prerender = true;
import CheckoutLayout from "../../layouts/CheckoutLayout.astro";
---

<CheckoutLayout title="Order Confirmed | TOK Skincare">
  <!-- ============== Order Found State ============== -->
  <div id="confirmation-found" class="hidden flex flex-col gap-8">
    <!-- Success Hero -->
    <section class="bg-canvas border border-hairline p-8 md:p-12 flex flex-col items-center text-center gap-5">
      <div class="w-16 h-16 bg-success-pale text-success-deep flex items-center justify-center">
        <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
      </div>

      <div class="flex flex-col gap-2 max-w-[520px]">
        <span class="font-sans text-overline font-bold tracking-overline text-primary">THANK YOU FOR YOUR ORDER</span>
        <h1 class="font-serif text-[32px] md:text-[40px] font-bold text-ink leading-[1.1] m-0">Order Confirmed!</h1>
        <p class="font-sans text-[15px] md:text-base text-mute leading-relaxed m-0">
          Your Thai skincare order has been received. A customer representative will contact you shortly to verify your delivery details.
        </p>
      </div>

      <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 font-sans text-caption font-semibold text-mute uppercase tracking-[0.5px] pt-2">
        <span class="flex items-center gap-2">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
          <span id="conf-order-date">—</span>
        </span>
        <span class="flex items-center gap-2">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 12V8H6a2 2 0 0 1-2-2c0-1.1.9-2 2-2h12v4"></path><path d="M4 6v12c0 1.1.9 2 2 2h14v-4"></path><path d="M18 12a2 2 0 0 0 0 4h4v-4Z"></path></svg>
          <span>Cash on Delivery</span>
        </span>
        <span class="flex items-center gap-2">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
          <span>Delivery in 2–5 days</span>
        </span>
      </div>
    </section>

    <!-- Order Summary + Customer Details (2-col on desktop) -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 items-start">
      <!-- Left: Items + Totals -->
      <section class="lg:col-span-7 bg-canvas border border-hairline flex flex-col">
        <header class="px-6 py-4 border-b border-hairline flex items-center justify-between">
          <h2 class="font-sans text-overline font-bold tracking-overline text-ink uppercase">Order Items</h2>
          <span class="font-sans text-caption font-semibold text-mute" id="conf-item-count">0 items</span>
        </header>

        <div class="flex flex-col" id="conf-items-list">
          <!-- Rendered client-side -->
        </div>

        <footer class="border-t border-hairline p-6 flex flex-col gap-2 bg-surface-soft">
          <div class="flex justify-between font-sans text-body-sm text-mute">
            <span>Items Subtotal</span>
            <span class="font-sans text-[18px] font-semibold text-ink" id="conf-subtotal">৳0</span>
          </div>
          <div class="flex justify-between font-sans text-body-sm text-mute">
            <span>Delivery Charge</span>
            <span class="font-sans text-[18px] font-semibold text-ink" id="conf-shipping">৳0</span>
          </div>
          <div class="border-t border-hairline-soft pt-3 mt-1 flex justify-between items-baseline">
            <span class="font-sans text-[15px] font-bold text-ink uppercase tracking-[0.5px]">Total Payable</span>
            <span class="font-sans text-[28px] font-bold text-primary leading-none" id="conf-total">৳0</span>
          </div>
          <p class="font-sans text-[11px] text-mute text-center leading-relaxed mt-2 m-0">
            Pay in cash to the delivery agent when your order arrives.
          </p>
        </footer>
      </section>

      <!-- Right: Customer + Delivery + What's Next -->
      <aside class="lg:col-span-5 flex flex-col gap-6 lg:sticky lg:top-6">
        <!-- Order + Customer Card -->
        <section class="bg-canvas border border-hairline p-6 flex flex-col gap-4">
          <div class="flex items-center justify-between pb-3 border-b border-hairline-soft">
            <span class="font-sans text-overline font-bold tracking-overline text-ink uppercase">Order Details</span>
            <span class="font-serif text-[18px] font-bold text-ink" id="conf-order-id">#—</span>
          </div>

          <div class="flex flex-col gap-3 text-body-sm font-sans">
            <div class="flex flex-col gap-0.5">
              <span class="text-caption font-semibold text-mute uppercase tracking-[0.5px]">Recipient</span>
              <span class="font-semibold text-ink" id="conf-name">—</span>
            </div>
            <div class="flex flex-col gap-0.5">
              <span class="text-caption font-semibold text-mute uppercase tracking-[0.5px]">Phone</span>
              <span class="font-semibold text-ink" id="conf-phone">—</span>
            </div>
            <div class="flex flex-col gap-0.5">
              <span class="text-caption font-semibold text-mute uppercase tracking-[0.5px]">Email</span>
              <span class="font-semibold text-ink" id="conf-email">—</span>
            </div>
            <div class="flex flex-col gap-0.5">
              <span class="text-caption font-semibold text-mute uppercase tracking-[0.5px]">Delivery Address</span>
              <span class="font-semibold text-ink leading-relaxed" id="conf-address">—</span>
            </div>
            <div class="flex flex-col gap-0.5" id="conf-notes-wrap" style="display:none;">
              <span class="text-caption font-semibold text-mute uppercase tracking-[0.5px]">Delivery Notes</span>
              <span class="font-medium text-body italic text-ink leading-relaxed" id="conf-notes">—</span>
            </div>
          </div>
        </section>

        <!-- What's Next Card -->
        <section class="bg-canvas border border-hairline p-6 flex flex-col gap-4">
          <span class="font-sans text-overline font-bold tracking-overline text-ink uppercase">What Happens Next</span>
          <ol class="flex flex-col gap-4 m-0 p-0 list-none">
            <li class="flex gap-3">
              <span class="shrink-0 w-7 h-7 bg-primary text-on-primary font-sans text-caption font-bold flex items-center justify-center">1</span>
              <div class="flex flex-col gap-0.5">
                <span class="font-sans text-body-sm-strong text-ink">Order Verification Call</span>
                <span class="font-sans text-caption text-mute leading-relaxed">Our team will call you within 24 hours to confirm your delivery address and time.</span>
              </div>
            </li>
            <li class="flex gap-3">
              <span class="shrink-0 w-7 h-7 bg-primary text-on-primary font-sans text-caption font-bold flex items-center justify-center">2</span>
              <div class="flex flex-col gap-0.5">
                <span class="font-sans text-body-sm-strong text-ink">Packed from Bangkok</span>
                <span class="font-sans text-caption text-mute leading-relaxed">Your products are sourced, sealed and packed for import with strict temperature control.</span>
              </div>
            </li>
            <li class="flex gap-3">
              <span class="shrink-0 w-7 h-7 bg-primary text-on-primary font-sans text-caption font-bold flex items-center justify-center">3</span>
              <div class="flex flex-col gap-0.5">
                <span class="font-sans text-body-sm-strong text-ink">Cash on Delivery</span>
                <span class="font-sans text-caption text-mute leading-relaxed">Pay the delivery agent in cash when your package arrives. Please keep exact change if possible.</span>
              </div>
            </li>
          </ol>
        </section>
      </aside>
    </div>

    <!-- CTAs -->
    <section class="flex flex-col sm:flex-row items-stretch sm:items-center justify-center gap-3 pt-2">
      <a
        href="/products"
        class="inline-flex items-center justify-center bg-primary text-on-primary font-sans text-[13px] font-bold tracking-[1.2px] uppercase h-14 px-8 rounded-none no-underline transition-colors duration-150 hover:bg-primary-pressed"
      >
        Continue Shopping
      </a>
      <a
        href="/"
        class="inline-flex items-center justify-center bg-transparent text-ink border-2 border-ink font-sans text-[13px] font-bold tracking-[1.2px] uppercase h-14 px-8 rounded-none no-underline transition-colors duration-150 hover:bg-surface-blush"
      >
        Return Home
      </a>
    </section>
  </div>

  <!-- ============== No Order Found State ============== -->
  <div id="confirmation-empty" class="hidden flex flex-col items-center text-center gap-6 bg-canvas border border-hairline p-8 md:p-12">
    <div class="w-16 h-16 bg-surface-card text-mute flex items-center justify-center">
      <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"></circle>
        <line x1="12" y1="8" x2="12" y2="12"></line>
        <line x1="12" y1="16" x2="12.01" y2="16"></line>
      </svg>
    </div>
    <div class="flex flex-col gap-2 max-w-[460px]">
      <span class="font-sans text-overline font-bold tracking-overline text-mute">NO RECENT ORDER</span>
      <h1 class="font-serif text-[28px] md:text-[32px] font-bold text-ink leading-tight m-0">We couldn't find your order</h1>
      <p class="font-sans text-[15px] text-mute leading-relaxed m-0">
        It looks like you arrived here directly. Once you place an order, you'll be brought back to this page with a full summary.
      </p>
    </div>
    <a
      href="/products"
      class="inline-flex items-center justify-center bg-primary text-on-primary font-sans text-[13px] font-bold tracking-[1.2px] uppercase h-14 px-8 rounded-none no-underline transition-colors duration-150 hover:bg-primary-pressed"
    >
      Browse Products
    </a>
  </div>

  <!-- ============== Loading State ============== -->
  <div id="confirmation-loading" class="flex flex-col items-center text-center gap-4 py-12">
    <div class="w-10 h-10 border-2 border-hairline border-t-primary rounded-full animate-spin"></div>
    <span class="font-sans text-caption font-semibold text-mute uppercase tracking-[1px]">Loading your order…</span>
  </div>
</CheckoutLayout>

<script>
  function initConfirmation() {
    const STORAGE_KEY = 'tok_last_order';

    const found = document.getElementById('confirmation-found');
    const empty = document.getElementById('confirmation-empty');
    const loading = document.getElementById('confirmation-loading');

    function formatBDT(val: number) {
      return '৳' + Number(val || 0).toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
    }

    function formatDate(iso: string) {
      try {
        const d = new Date(iso);
        return d.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' });
      } catch {
        return iso || '—';
      }
    }

    function showState(state: 'found' | 'empty') {
      if (loading) loading.style.display = 'none';
      if (state === 'found' && found) {
        found.classList.remove('hidden');
        if (empty) empty.classList.add('hidden');
      } else if (empty) {
        empty.classList.remove('hidden');
        if (found) found.classList.add('hidden');
      }
    }

    let order: any = null;
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (raw) order = JSON.parse(raw);
    } catch {
      order = null;
    }

    if (!order || !order.orderId) {
      showState('empty');
      return;
    }

    // Populate details
    const setText = (id: string, val: string) => {
      const el = document.getElementById(id);
      if (el) el.textContent = val;
    };

    setText('conf-order-id', `#${order.orderId}`);
    setText('conf-order-date', formatDate(order.createdAt));
    setText('conf-name', order.user?.name || '—');
    setText('conf-phone', order.user?.phone || '—');
    setText('conf-email', order.user?.email && order.user.email.trim() ? order.user.email : 'Not provided');

    const addr = order.user?.address
      ? `${order.user.address}, ${order.user.city || ''}, Bangladesh`.replace(/^, |, $/g, '')
      : '—';
    setText('conf-address', addr);

    if (order.user?.notes && String(order.user.notes).trim()) {
      const wrap = document.getElementById('conf-notes-wrap');
      if (wrap) wrap.style.display = '';
      setText('conf-notes', order.user.notes);
    }

    setText('conf-subtotal', formatBDT(order.subtotal));
    setText('conf-shipping', formatBDT(order.shipping));
    setText('conf-total', formatBDT(order.total));

    // Render items
    const itemsList = document.getElementById('conf-items-list');
    const itemCountEl = document.getElementById('conf-item-count');
    const items = Array.isArray(order.items) ? order.items : [];
    const totalQty = items.reduce((s: number, i: any) => s + (i.quantity || 0), 0);
    if (itemCountEl) itemCountEl.textContent = `${totalQty} item${totalQty === 1 ? '' : 's'}`;

    if (itemsList) {
      itemsList.innerHTML = '';
      items.forEach((item: any) => {
        const row = document.createElement('div');
        row.className = 'flex items-center gap-4 p-6 border-b border-hairline-soft last:border-b-0';
        row.innerHTML = `
          <a href="/products/${item.slug || ''}" class="shrink-0 block w-16 h-[80px] md:w-20 md:h-[100px] overflow-hidden bg-surface-card border border-hairline-soft" aria-label="View ${item.name}">
            <img src="${item.image || ''}" alt="${item.name || ''}" class="w-full h-full object-cover" loading="lazy" />
          </a>
          <div class="flex-1 min-w-0 flex flex-col gap-1">
            <span class="font-sans text-caption font-bold tracking-[2px] uppercase text-mute">${item.brand || ''}</span>
            <a href="/products/${item.slug || ''}" class="no-underline text-ink">
              <h3 class="font-sans text-[15px] md:text-base font-semibold leading-snug line-clamp-2 m-0">${item.name || ''}</h3>
            </a>
            <span class="font-sans text-caption text-mute">Qty: ${item.quantity || 1}</span>
          </div>
          <div class="shrink-0 text-right">
            <span class="font-sans text-[18px] md:text-[20px] font-semibold text-ink leading-none">${formatBDT(item.price * item.quantity)}</span>
          </div>
        `;
        itemsList.appendChild(row);
      });
    }

    showState('found');
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initConfirmation);
  } else {
    initConfirmation();
  }
</script>
