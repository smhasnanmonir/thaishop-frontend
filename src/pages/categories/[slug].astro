---
export const prerender = false;
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/ui/Breadcrumb.astro";
import ProductCard from "../../components/ui/ProductCard.astro";
import Pagination from "../../components/ui/Pagination.astro";
import { api } from "../../lib/api";
import type { Category, Product } from "../../lib/api";

const PAGE_SIZE = 15;

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect("/404");
}

const page = Math.max(1, parseInt(Astro.url.searchParams.get("page") || "1"));

let products: Product[] = [];
let totalPages = 1;
let total = 0;
let displayName = (slug || "").replace(/-/g, " ");

try {
  const data = await api.getProductsByCategory(slug, page, PAGE_SIZE);
  products = data.result || [];
  totalPages = data.totalPages || 1;
  total = data.total || 0;
  if (products.length > 0 && products[0].category) {
    displayName = products[0].category;
  }
} catch (error) {
  console.error(`Failed to load products for category "${slug}":`, error);
}

const heading = displayName.replace(/\b\w/g, (c) => c.toUpperCase());
const startIdx = total > 0 ? (page - 1) * PAGE_SIZE + 1 : 0;
const endIdx = Math.min(page * PAGE_SIZE, total);
---

<BaseLayout
  title={`${heading}${page > 1 ? ` - Page ${page}` : ""} | Thai Skincare | TOK Bangladesh`}
  description={`Shop ${heading} from authentic Thai skincare brands.`}
>
  <div class="min-h-screen bg-canvas">
    <div class="max-w-[1536px] mx-auto px-4 md:px-6 py-12 md:py-16">

      <Breadcrumb items={[{ label: "Home", href: "/" }, { label: "Categories", href: "/categories" }, { label: heading }]} />

      <div class="flex flex-col items-center text-center gap-2.5 mb-12 md:mb-16 max-w-2xl mx-auto">
        <span class="font-sans text-[11px] font-bold tracking-[2.5px] uppercase text-primary leading-none">CATEGORY</span>
        <h1 class="font-serif text-[34px] md:text-[44px] lg:text-[48px] font-bold text-ink leading-tight m-0">{heading}</h1>
        {total > 0 && (
          <p class="font-sans text-sm md:text-base text-mute m-0 mt-2 leading-relaxed">
            Showing {startIdx}&ndash;{endIdx} of {total} products
          </p>
        )}
      </div>

      {products.length > 0 ? (
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-1 sm:gap-2">
          {products.map((prod) => <ProductCard product={prod} />)}
        </div>
      ) : (
        <div class="flex flex-col items-center justify-center py-20 text-center gap-6 border border-dashed border-hairline">
          <div class="text-stone">
            <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
          </div>
          <div class="flex flex-col gap-2 max-w-[400px]">
            <h2 class="font-serif text-heading-xl text-ink font-bold m-0">No Products Yet</h2>
            <p class="font-sans text-[15px] text-mute leading-relaxed m-0">We currently have no products in this category.</p>
          </div>
          <a href="/categories" class="inline-flex items-center justify-center bg-primary text-on-primary font-sans text-[13px] font-bold tracking-[1.2px] uppercase h-12 px-8 rounded-none no-underline transition-colors duration-150 hover:bg-primary-pressed">Browse All Categories</a>
        </div>
      )}

      {totalPages > 1 && (
        <div class="flex items-center justify-center border-t border-hairline pt-6 mt-8">
          <Pagination currentPage={page} totalPages={totalPages} />
        </div>
      )}
    </div>
  </div>
</BaseLayout>

<!--
  Server-rendered (prerender = false). Pagination links use ?page=N so
  each click triggers a full Astro server re-render with the new page
  number. No client script required.
-->
