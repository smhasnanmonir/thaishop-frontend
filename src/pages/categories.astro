---
export const prerender = true;
import BaseLayout from "../layouts/BaseLayout.astro";
import ImageCard from "../components/ui/ImageCard.astro";
import { api } from "../lib/api";

import type { Category } from "../lib/api";

let categories: Category[] = [];
try {
  const homeData = await api.getHomeContent();
  categories = homeData.categories || [];
} catch (error) {
  console.error("Failed to load categories list:", error);
}
---

<BaseLayout
  title="All Categories | TOK Skincare Bangladesh"
  description="Browse Thai skincare categories. Find authentic Thai cleansers, moisturisers, serums, sunscreens, and body care products."
>
  <div class="min-h-screen">
    <div class="mx-auto px-4 md:px-6 py-12 md:py-16" style="max-width: 1536px;">
      {/* Page Header */}
      <div class="flex flex-col items-center text-center gap-2.5 mb-12 md:mb-16 max-w-2xl mx-auto">
        <div class="font-sans text-[11px] font-bold tracking-[1.5px] uppercase text-mute/70 flex items-center gap-1.5 mb-1.5">
          <a href="/" class="hover:text-primary transition-colors no-underline text-mute">Home</a>
          <span class="text-stone">&bull;</span>
          <span class="text-ink font-semibold">Categories</span>
        </div>

        <span class="font-sans text-[12px] font-bold tracking-[2.5px] uppercase text-primary leading-none">SHOP RANGE</span>
        <h1 class="font-serif text-[34px] md:text-[44px] lg:text-[48px] font-bold text-ink leading-tight m-0">All Categories</h1>
        <p class="font-sans text-sm md:text-base text-mute m-0 mt-2  leading-relaxed">
          Explore our curated collections of authentic skin therapies imported from Bangkok.
        </p>
      </div>

      {/* Categories Grid */}
      {categories.length > 0 ? (
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
          {categories.map((cat) => (
            <ImageCard
              href={`/categories/${cat.slug}`}
              image={cat.img || "https://images.unsplash.com/photo-1512290923902-8a9f81dc236c?q=80&w=400&auto=format&fit=crop"}
              alt={cat.name}
              overline="SHOP RANGE"
              title={cat.name}
              cta="Explore Collection"
              aspect="square"
            />
          ))}
        </div>
      ) : (
        <div class="text-center py-20">
          <p class="font-sans text-base text-mute m-0">Loading categories...</p>
        </div>
      )}
    </div>
  </div>
</BaseLayout>
