---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProductCard from "../../components/ui/ProductCard.astro";
import { api } from "../../lib/api";

let categories = [];
let brands = [];
let concerns = [];
let types = [];
let initialProducts = [];
let initialTotal = 0;
let initialTotalPages = 1;

try {
  const homeData = await api.getHomeContent();
  categories = homeData.categories || [];
  brands = homeData.brands || [];
  concerns = homeData.concerns || [];
  types = homeData.types || [];

  const productsData = await api.getAllProducts(1, 12);
  initialProducts = productsData.result || [];
  initialTotal = productsData.total || 0;
  initialTotalPages = productsData.totalPages || 1;
} catch (error) {
  console.error("Failed to load products/listing static content:", error);
}
---

<BaseLayout
  title="All Skincare | TOK Skincare Bangladesh"
  description="Explore authentic Thai skincare products. Filter by category, skin concern, skin type, and brands. 100% original, imported directly from Bangkok."
>
  <div class="max-w-[1536px] mx-auto px-4 md:px-6 py-8 pb-[72px]">
    {/* Page Header */}
    <div class="flex flex-col items-center text-center gap-2.5 mb-12 md:mb-16 max-w-2xl mx-auto">
      <div class="font-sans text-[11px] font-bold tracking-[1.5px] uppercase text-mute/70 flex items-center gap-1.5 mb-1.5">
        <a href="/" class="hover:text-primary transition-colors no-underline text-mute">Home</a>
        <span class="text-stone">&bull;</span>
        <span class="text-ink font-semibold">All Products</span>
      </div>

      <span class="font-sans text-[12px] font-bold tracking-[2.5px] uppercase text-primary leading-none">SHOP RANGE</span>
      <h1 class="font-serif text-[34px] md:text-[44px] lg:text-[48px] font-bold text-ink leading-tight m-0">Skincare Collection</h1>
      <p class="font-sans text-sm md:text-base text-mute m-0 mt-2  leading-relaxed" id="total-count-label">
        Showing {initialProducts.length} of {initialTotal} products
      </p>
    </div>

    {/* Layout */}
    <div class="grid grid-cols-1 lg:grid-cols-[260px_1fr] gap-8 items-start">
      {/* Sidebar Filters */}
      <aside
        class="bg-canvas border border-hairline p-4 flex flex-col gap-5 max-lg:fixed max-lg:top-0 max-lg:left-0 max-lg:w-[300px] max-lg:h-full max-lg:z-[1200] max-lg:shadow-xl max-lg:-translate-x-full max-lg:transition-transform max-lg:duration-300 data-[open]:max-lg:translate-x-0"
        id="sidebar-filter-panel"
      >
        {/* Mobile Header */}
        <div class="hidden max-lg:flex items-center justify-between border-b border-hairline pb-3">
          <h3 class="font-serif text-xl font-bold m-0">Filters</h3>
          <button class="text-2xl text-mute" id="close-filters-btn">&times;</button>
        </div>

        {/* Category Filter */}
        <div class="border-b border-hairline-soft pb-4 last:border-b-0 last:pb-0">
          <h3 class="font-sans text-[11px] font-bold tracking-[2px] uppercase text-ink mb-2 m-0">Category</h3>
          <div class="flex flex-col gap-1.5 max-h-[200px] overflow-y-auto pr-1">
            {categories.map(cat => (
              <label class="flex items-center gap-2 cursor-pointer font-sans text-[14px] text-body">
                <input type="checkbox" name="category" value={cat.slug} class="w-4 h-4 border border-stone rounded-none cursor-pointer accent-primary filter-checkbox" />
                <span class="select-none">{cat.name}</span>
              </label>
            ))}
          </div>
        </div>

        {/* Skin Type Filter */}
        <div class="border-b border-hairline-soft pb-4 last:border-b-0 last:pb-0">
          <h3 class="font-sans text-[11px] font-bold tracking-[2px] uppercase text-ink mb-2 m-0">Skin Type</h3>
          <div class="flex flex-col gap-1.5 max-h-[200px] overflow-y-auto pr-1">
            {types.map(tp => (
              <label class="flex items-center gap-2 cursor-pointer font-sans text-[14px] text-body">
                <input type="checkbox" name="skin_type" value={tp.slug} class="w-4 h-4 border border-stone rounded-none cursor-pointer accent-primary filter-checkbox" />
                <span class="select-none">{tp.name}</span>
              </label>
            ))}
          </div>
        </div>

        {/* Concern Filter */}
        <div class="border-b border-hairline-soft pb-4 last:border-b-0 last:pb-0">
          <h3 class="font-sans text-[11px] font-bold tracking-[2px] uppercase text-ink mb-2 m-0">Concern</h3>
          <div class="flex flex-col gap-1.5 max-h-[200px] overflow-y-auto pr-1">
            {concerns.map(con => (
              <label class="flex items-center gap-2 cursor-pointer font-sans text-[14px] text-body">
                <input type="checkbox" name="skin_concern" value={con.slug} class="w-4 h-4 border border-stone rounded-none cursor-pointer accent-primary filter-checkbox" />
                <span class="select-none">{con.name}</span>
              </label>
            ))}
          </div>
        </div>

        {/* Brand Filter */}
        <div class="border-b border-hairline-soft pb-4 last:border-b-0 last:pb-0">
          <h3 class="font-sans text-[11px] font-bold tracking-[2px] uppercase text-ink mb-2 m-0">Brand</h3>
          <div class="flex flex-col gap-1.5 max-h-[200px] overflow-y-auto pr-1">
            {brands.map(br => (
              <label class="flex items-center gap-2 cursor-pointer font-sans text-[14px] text-body">
                <input type="checkbox" name="brand" value={br.slug} class="w-4 h-4 border border-stone rounded-none cursor-pointer accent-primary filter-checkbox" />
                <span class="select-none">{br.name}</span>
              </label>
            ))}
          </div>
        </div>

        {/* Clear All */}
        <button
          class="w-full font-sans text-[11px] font-bold tracking-[1px] uppercase text-mute border border-hairline py-2 hover:text-primary hover:border-primary transition-colors duration-150"
          id="clear-filters-btn"
        >
          Clear All
        </button>
      </aside>

      {/* Products Section */}
      <div class="flex flex-col gap-8">
        {/* Mobile Filter Bar */}
        <div class="hidden max-lg:flex items-center justify-between border-b border-hairline pb-3">
          <button class="inline-flex items-center gap-2 border border-hairline px-4 py-2 font-sans text-xs font-bold uppercase tracking-[0.5px]" id="mobile-filter-toggle">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"></polygon>
            </svg>
            <span>Filters</span>
          </button>
          <span class="font-sans text-[13px] text-mute" id="mobile-count-label">{initialTotal} products</span>
        </div>

        {/* Shimmer Loader */}
        <div class="hidden grid-cols-2 sm:grid-cols-2 lg:grid-cols-3 gap-3 sm:gap-6" id="plp-shimmer">
          {[1,2,3,4,5,6].map(() => (
            <div class="h-[380px] bg-gradient-to-r from-surface-soft via-secondary-bg to-surface-soft bg-[length:200%_100%] animate-[shimmer_1.5s_infinite]" />
          ))}
        </div>

        {/* Empty State */}
        <div class="hidden text-center py-8 font-sans text-mute border border-dashed border-hairline" id="plp-empty">
          <p class="m-0">No products match your active filters. Try clearing some selections.</p>
        </div>

        {/* Products Grid */}
        <div class="grid grid-cols-2 sm:grid-cols-2 lg:grid-cols-3 gap-3 sm:gap-6" id="plp-products-grid">
          {initialProducts.map(prod => (
            <ProductCard product={prod} />
          ))}
        </div>

        {/* Pagination */}
        <div
          class="flex items-center justify-center gap-6 border-t border-hairline pt-6 mt-4"
          id="plp-pagination"
          data-current-page="1"
          data-total-pages={initialTotalPages}
        >
          <button
            class="font-sans text-[11px] font-bold tracking-[1px] uppercase border border-hairline px-6 py-2 hover:bg-ink hover:text-on-dark transition-colors duration-150 disabled:text-ash disabled:border-hairline-soft disabled:cursor-not-allowed"
            id="prev-page-btn"
            disabled
          >
            &larr; Previous
          </button>
          <span class="font-sans text-[14px] text-ink font-semibold">
            Page <span id="current-page-num">1</span> of <span id="total-pages-num">{initialTotalPages}</span>
          </span>
          <button
            class="font-sans text-[11px] font-bold tracking-[1px] uppercase border border-hairline px-6 py-2 hover:bg-ink hover:text-on-dark transition-colors duration-150 disabled:text-ash disabled:border-hairline-soft disabled:cursor-not-allowed"
            id="next-page-btn"
            disabled={initialTotalPages <= 1}
          >
            Next &rarr;
          </button>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const filterPanel = document.getElementById('sidebar-filter-panel');
    const mobileToggle = document.getElementById('mobile-filter-toggle');
    const mobileClose = document.getElementById('close-filters-btn');
    
    const checkboxes = document.querySelectorAll('.filter-checkbox');
    const clearBtn = document.getElementById('clear-filters-btn');
    
    const productsGrid = document.getElementById('plp-products-grid');
    const plpShimmer = document.getElementById('plp-shimmer');
    const plpEmpty = document.getElementById('plp-empty');
    
    const totalLabel = document.getElementById('total-count-label');
    const mobileTotalLabel = document.getElementById('mobile-count-label');

    const pagination = document.getElementById('plp-pagination');
    const prevBtn = document.getElementById('prev-page-btn');
    const nextBtn = document.getElementById('next-page-btn');
    const pageNum = document.getElementById('current-page-num');
    const totalPagesNum = document.getElementById('total-pages-num');

    let currentPage = 1;
    let totalPages = 1;

    function formatBDT(val: number) {
      return '৳' + val.toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
    }

    mobileToggle?.addEventListener('click', () => {
      filterPanel?.setAttribute('data-open', '');
      const scrim = document.getElementById('nav-scrim-layer');
      if (scrim) {
        scrim.classList.add('open');
        scrim.addEventListener('click', closeMobileFilters);
      }
    });

    function closeMobileFilters() {
      filterPanel?.removeAttribute('data-open');
      const scrim = document.getElementById('nav-scrim-layer');
      if (scrim) {
        scrim.classList.remove('open');
        scrim.removeEventListener('click', closeMobileFilters);
      }
    }

    mobileClose?.addEventListener('click', closeMobileFilters);

    const urlParams = new URLSearchParams(window.location.search);
    let hasUrlFilters = false;

    checkboxes.forEach((cb: HTMLInputElement) => {
      const name = cb.name;
      const val = cb.value;
      if (urlParams.get(name) === val || urlParams.get(name.replace('_', '-')) === val) {
        cb.checked = true;
        hasUrlFilters = true;
      }
    });

    if (hasUrlFilters) fetchFilteredProducts(1);

    checkboxes.forEach((cb) => {
      cb.addEventListener('change', () => {
        currentPage = 1;
        fetchFilteredProducts(1);
      });
    });

    clearBtn?.addEventListener('click', () => {
      checkboxes.forEach((cb: HTMLInputElement) => cb.checked = false);
      currentPage = 1;
      fetchFilteredProducts(1);
    });

    prevBtn?.addEventListener('click', () => {
      if (currentPage > 1) {
        currentPage--;
        fetchFilteredProducts(currentPage);
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }
    });

    nextBtn?.addEventListener('click', () => {
      if (currentPage < totalPages) {
        currentPage++;
        fetchFilteredProducts(currentPage);
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }
    });

    async function fetchFilteredProducts(page: number) {
      if (plpShimmer) plpShimmer.style.display = 'grid';
      if (productsGrid) productsGrid.style.display = 'none';
      if (plpEmpty) plpEmpty.style.display = 'none';

      const filterGroups: Record<string, string[]> = {};
      
      checkboxes.forEach((cb: HTMLInputElement) => {
        if (cb.checked) {
          const name = cb.name;
          const val = cb.value;
          if (!filterGroups[name]) filterGroups[name] = [];
          filterGroups[name].push(val);
        }
      });

      const filtersString = Object.entries(filterGroups)
        .map(([key, values]) => `${key}:${values.join('|')}`)
        .join(',');

      const queryParams = new URLSearchParams({
        page: page.toString(),
        pageSize: '12',
      });
      if (filtersString) queryParams.append('filters', filtersString);

      try {
        const res = await fetch(`https://backend.tokbd.com/api/products/all?${queryParams.toString()}`);
        if (res.ok) {
          const data = await res.json();
          const items = data.result || [];
          const total = data.total || 0;
          totalPages = data.totalPages || 1;
          currentPage = data.currentPage || 1;

          if (plpShimmer) plpShimmer.style.display = 'none';

          if (pageNum) pageNum.innerText = currentPage.toString();
          if (totalPagesNum) totalPagesNum.innerText = totalPages.toString();
          
          if (prevBtn) (prevBtn as HTMLButtonElement).disabled = currentPage <= 1;
          if (nextBtn) (nextBtn as HTMLButtonElement).disabled = currentPage >= totalPages;

          if (items.length === 0) {
            if (plpEmpty) plpEmpty.style.display = 'block';
            if (totalLabel) totalLabel.innerText = 'Showing 0 products';
            if (mobileTotalLabel) mobileTotalLabel.innerText = '0 products';
            return;
          }

          if (productsGrid) {
            productsGrid.innerHTML = '';
            
            items.forEach((prod: any) => {
              const currentPrice = parseFloat(prod.price);
              const originalPrice = parseFloat(prod.origin_price);
              const onSale = originalPrice > currentPrice;
              const discountPercent = onSale ? Math.round(((originalPrice - currentPrice) / originalPrice) * 100) : 0;
              const imgUrl = prod.card_photo || prod.img || "";

              const card = document.createElement('div');
              card.className = 'group flex flex-col bg-white border border-hairline-soft rounded-none';
              card.setAttribute('data-id', prod.id);
              card.innerHTML = `
                <a href="/products/${prod.slug}" class="block relative" aria-label="View details for ${prod.name}">
                  <div class="relative w-full aspect-square sm:aspect-[3/4] bg-surface-card overflow-hidden">
                    <img src="${imgUrl}" alt="${prod.name}" class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
                    <div class="absolute top-3 left-3 flex flex-col gap-1.5 z-10">
                      ${onSale ? `<span class="inline-flex items-center font-sans text-[12px] font-bold tracking-[1.5px] uppercase px-3 py-1.5 leading-none rounded-none bg-ink text-on-dark">SALE -${discountPercent}%</span>` : ''}
                      ${!prod.stock ? `<span class="inline-flex items-center font-sans text-[11px] font-bold tracking-[1.5px] uppercase px-3 py-1.5 leading-none rounded-none bg-mute text-on-primary">SOLD OUT</span>` : ''}
                      ${prod.origin_country === 'thailand' ? `<span class="inline-flex items-center font-sans text-[11px] font-bold tracking-[1.5px] uppercase px-3 py-1.5 leading-none rounded-none bg-accent-gold text-on-dark">THAI</span>` : ''}
                    </div>
                  </div>
                </a>
                <div class="flex flex-col flex-1 p-3.5 sm:p-5 gap-3">
                  <span class="font-sans text-[12px] md:text-[13px] font-bold tracking-[2px] uppercase text-mute">${prod.brand}</span>
                  <a href="/products/${prod.slug}" class="no-underline text-ink block flex-1">
                    <h3 class="font-sans text-[15px] md:text-[16px] font-semibold leading-[1.4] line-clamp-2 text-ink m-0">${prod.name}</h3>
                  </a>
                  <div class="flex items-baseline gap-2 mt-1">
                    <span class="font-sans text-[20px] md:text-[22px] font-bold text-ink leading-none">${formatBDT(currentPrice)}</span>
                    ${onSale ? `<span class="font-sans text-[14px] md:text-[15px] text-ash line-through">${formatBDT(originalPrice)}</span>` : ''}
                  </div>
                  <div class="mt-auto pt-4">
                    ${prod.stock ? `
                      <button class="flex items-center justify-center gap-1.5 sm:gap-2 w-full h-12 px-2 sm:px-6 bg-primary text-on-primary font-sans text-[11px] sm:text-[13px] font-bold tracking-[0.5px] sm:tracking-[1.2px] uppercase rounded-none cursor-pointer hover:bg-primary-pressed active:bg-primary-pressed transition-colors duration-150 whitespace-nowrap" data-add-to-cart data-id="${prod.id}" data-name="${prod.name}" data-price="${prod.price}" data-img="${imgUrl}">
                        <svg class="hidden sm:block" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"></path>
                          <line x1="3" y1="6" x2="21" y2="6"></line>
                          <path d="M16 10a4 4 0 01-8 0"></path>
                        </svg>
                        <span>Add to Bag</span>
                      </button>
                    ` : `
                      <span class="flex items-center justify-center w-full h-12 px-2 border border-hairline-soft font-sans text-[11px] sm:text-[13px] font-semibold text-mute uppercase rounded-none bg-surface-soft whitespace-nowrap">Out of Stock</span>
                    `}
                  </div>
                </div>
              `;
              productsGrid.appendChild(card);
            });

            productsGrid.style.display = 'grid';
          }

          const endCount = Math.min(currentPage * 12, total);
          const startCount = (currentPage - 1) * 12 + 1;
          
          if (totalLabel) totalLabel.innerText = `Showing ${startCount}-${endCount} of ${total} products`;
          if (mobileTotalLabel) mobileTotalLabel.innerText = `${total} products`;
        }
      } catch (err) {
        console.error('Error fetching filtered list:', err);
        if (plpShimmer) plpShimmer.style.display = 'none';
        if (plpEmpty) plpEmpty.style.display = 'block';
      }
    }
  });
</script>
