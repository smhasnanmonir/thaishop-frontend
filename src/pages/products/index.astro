---
export const prerender = false;
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProductCard from "../../components/ui/ProductCard.astro";
import Pagination from "../../components/ui/Pagination.astro";
import { api } from "../../lib/api";
import type { Category, Brand, SkinConcern, SkinType, Product, ProductFilter } from "../../lib/api";

const PAGE_SIZE = 20;

// ── Parse URL params ──
const page = Math.max(1, parseInt(Astro.url.searchParams.get("page") || "1"));
const filtersParam = Astro.url.searchParams.get("filters") || "";

function parseFilters(raw: string): ProductFilter {
  const filters: ProductFilter = {};
  if (!raw) return filters;
  raw.split(",").forEach((pair) => {
    const [key, vals] = pair.split(":");
    if (key && vals) {
      const validKeys = ["category", "brand", "skin_type", "skin_concern"];
      if (validKeys.includes(key.trim())) {
        (filters as any)[key.trim()] = vals.split("|").filter(Boolean);
      }
    }
  });
  return filters;
}

const filters = parseFilters(filtersParam);

// ── Load data ──
let categories: Category[] = [];
let brands: Brand[] = [];
let concerns: SkinConcern[] = [];
let types: SkinType[] = [];
let products: Product[] = [];
let totalPages = 1;
let total = 0;

try {
  const [homeData, productsData] = await Promise.all([
    api.getHomeContent(),
    api.getAllProducts(page, PAGE_SIZE, filters),
  ]);
  categories = homeData.categories || [];
  brands = homeData.brands || [];
  concerns = homeData.concerns || [];
  types = homeData.types || [];

  products = productsData.result || [];
  total = productsData.total || 0;
  totalPages = productsData.totalPages || 1;
} catch (error) {
  console.error("Failed to load products listing:", error);
}

const allFilterCategories = [
  { key: "category", label: "Category", items: categories.map(c => ({ value: c.slug, label: c.name })) },
  { key: "brand", label: "Brand", items: brands.map(b => ({ value: b.slug, label: b.name })) },
  { key: "skin_type", label: "Skin Type", items: types.map(t => ({ value: t.slug, label: t.name })) },
  { key: "skin_concern", label: "Concern", items: concerns.map(c => ({ value: c.slug, label: c.name })) },
];

const startIdx = total > 0 ? (page - 1) * PAGE_SIZE + 1 : 0;
const endIdx = Math.min(page * PAGE_SIZE, total);

// Count active filters for badge
const activeFilterCount = Object.values(filters).reduce((sum, arr) => sum + (arr?.length || 0), 0);
---

<BaseLayout
  title="All Skincare | TOK Skincare Bangladesh"
  description="Explore authentic Thai skincare products. Filter by category, skin concern, skin type, and brands. 100% original, imported directly from Bangkok."
>
  <div class="max-w-[1536px] mx-auto px-4 md:px-6 py-8 pb-[72px]">
    {/* Page Header */}
    <div class="flex flex-col items-center text-center gap-2.5 mb-12 md:mb-16 max-w-2xl mx-auto">
      <div class="font-sans text-[11px] font-bold tracking-[1.5px] uppercase text-mute/70 flex items-center gap-1.5 mb-1.5">
        <a href="/" class="hover:text-primary transition-colors no-underline text-mute">Home</a>
        <span class="text-stone">&bull;</span>
        <span class="text-ink font-semibold">All Products</span>
      </div>
      <span class="font-sans text-[12px] font-bold tracking-[2.5px] uppercase text-primary leading-none">SHOP RANGE</span>
      <h1 class="font-serif text-[34px] md:text-[44px] lg:text-[48px] font-bold text-ink leading-tight m-0">Skincare Collection</h1>
      <p class="font-sans text-sm md:text-base text-mute m-0 mt-2 leading-relaxed">
        {total > 0
          ? <>Showing {startIdx}&ndash;{endIdx} of {total} products</>
          : <>0 products</>
        }
      </p>
    </div>

    {/* Mobile Filter Bar */}
    <div class="flex items-center justify-between border-b border-hairline pb-3 mb-6 lg:hidden">
      <button class="inline-flex items-center gap-2 border border-hairline px-4 py-2 font-sans text-xs font-bold uppercase tracking-[0.5px] cursor-pointer hover:border-ink transition-colors" id="mobile-filter-toggle" type="button">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"></polygon>
        </svg>
        <span>Filters</span>
        {activeFilterCount > 0 && (
          <span class="inline-flex bg-primary text-on-primary text-[10px] font-bold w-5 h-5 items-center justify-center rounded-full" id="active-filter-count">{activeFilterCount}</span>
        )}
      </button>
      <span class="font-sans text-[13px] text-mute">{total} products</span>
    </div>

    {/* Layout */}
    <div class="grid grid-cols-1 lg:grid-cols-[260px_1fr] gap-8 items-start">

      {/* ── Desktop Sidebar Filters ── */}
      <aside class="bg-canvas border border-hairline p-4 flex-col gap-5 hidden lg:flex" id="desktop-filter-panel">
        {allFilterCategories.map(section => (
          <div class="border-b border-hairline-soft pb-4 last:border-b-0 last:pb-0">
            <h3 class="font-sans text-[11px] font-bold tracking-[2px] uppercase text-ink mb-2 m-0">{section.label}</h3>
            <div class="flex flex-col gap-1.5 max-h-[200px] overflow-y-auto pr-1">
              {section.items.map(item => (
                <label class="flex items-center gap-2 cursor-pointer font-sans text-[14px] text-body">
                  <input
                    type="checkbox"
                    name={section.key}
                    value={item.value}
                    class="w-4 h-4 border border-stone rounded-none cursor-pointer accent-primary filter-checkbox"
                    data-group={section.key}
                    checked={filters[section.key as keyof ProductFilter]?.includes(item.value)}
                  />
                  <span class="select-none">{item.label}</span>
                </label>
              ))}
            </div>
          </div>
        ))}
        <a href="/products" class="w-full text-center font-sans text-[11px] font-bold tracking-[1px] uppercase text-mute border border-hairline py-2 hover:text-primary hover:border-primary transition-colors duration-150 no-underline block">
          Clear All
        </a>
      </aside>

      {/* ── Mobile Slide-Out Filter Panel ── */}
      <div id="mobile-filter-scrim" class="fixed inset-0 bg-ink/30 z-[1200] opacity-0 pointer-events-none transition-opacity duration-200"></div>
      <aside
        class="fixed top-0 left-0 w-[300px] max-w-[85vw] h-full bg-canvas z-[1201] shadow-xl flex flex-col transition-transform duration-300"
        id="mobile-filter-panel"
        style="transform: translateX(-100%);"
      >
        <div class="h-[60px] px-5 flex items-center justify-between border-b border-hairline shrink-0">
          <h3 class="font-sans text-[14px] font-bold text-ink m-0">Filters</h3>
          <button class="w-10 h-10 flex items-center justify-center text-mute hover:text-ink transition-colors cursor-pointer" id="mobile-filter-close" type="button" aria-label="Close filters">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
          </button>
        </div>
        <div class="flex-1 overflow-y-auto p-4 flex flex-col gap-5">
          {allFilterCategories.map(section => (
            <div class="border-b border-hairline-soft pb-4 last:border-b-0 last:pb-0">
              <h3 class="font-sans text-[11px] font-bold tracking-[2px] uppercase text-ink mb-2 m-0">{section.label}</h3>
              <div class="flex flex-col gap-1.5">
                {section.items.map(item => (
                  <label class="flex items-center gap-2 cursor-pointer font-sans text-[14px] text-body">
                    <input
                      type="checkbox"
                      name={section.key}
                      value={item.value}
                      class="w-4 h-4 border border-stone rounded-none cursor-pointer accent-primary filter-checkbox"
                      data-group={section.key}
                      checked={filters[section.key as keyof ProductFilter]?.includes(item.value)}
                    />
                    <span class="select-none">{item.label}</span>
                  </label>
                ))}
              </div>
            </div>
          ))}
        </div>
        <div class="shrink-0 border-t border-hairline p-4 flex flex-col gap-2 bg-canvas">
          <button class="w-full bg-primary text-on-primary font-sans text-[13px] font-bold tracking-[1px] uppercase h-11 rounded-none cursor-pointer transition-colors hover:bg-primary-pressed" id="mobile-filter-apply" type="button">Apply Filters</button>
          <a href="/products" class="w-full bg-transparent text-mute border border-hairline font-sans text-[11px] font-bold tracking-[1px] uppercase h-9 rounded-none cursor-pointer hover:text-primary hover:border-primary transition-colors text-center no-underline block">Clear All</a>
        </div>
      </aside>

      {/* ── Products Section ── */}
      <div class="flex flex-col gap-8">
        {/* Empty State */}
        {products.length === 0 ? (
          <div class="flex flex-col items-center justify-center py-20 text-center gap-6 border border-dashed border-hairline">
            <div class="text-stone">
              <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
            </div>
            <div class="flex flex-col gap-2 max-w-[400px]">
              <h2 class="font-serif text-heading-xl text-ink font-bold m-0">No Products Found</h2>
              <p class="font-sans text-[15px] text-mute leading-relaxed m-0">No products match your active filters. Try clearing some selections.</p>
            </div>
            <a href="/products" class="inline-flex items-center justify-center bg-primary text-on-primary font-sans text-[13px] font-bold tracking-[1.2px] uppercase h-12 px-8 rounded-none no-underline transition-colors duration-150 hover:bg-primary-pressed">Clear Filters</a>
          </div>
        ) : (
          <div class="grid grid-cols-2 md:grid-cols-3 xl:grid-cols-5 gap-1 sm:gap-2">
            {products.map(prod => (
              <ProductCard product={prod} />
            ))}
          </div>
        )}

        {/* Pagination */}
        {totalPages > 1 && (
          <div class="flex items-center justify-center border-t border-hairline pt-6 mt-4">
            <Pagination currentPage={page} totalPages={totalPages} />
          </div>
        )}
      </div>
    </div>
  </div>
</BaseLayout>

<script is:inline>
(function () {
  function initFilters() {
    var desktopFilterPanel = document.getElementById("desktop-filter-panel");
    var mobileFilterPanel = document.getElementById("mobile-filter-panel");
    var mobileFilterScrim = document.getElementById("mobile-filter-scrim");
    var mobileToggle = document.getElementById("mobile-filter-toggle");
    var mobileClose = document.getElementById("mobile-filter-close");
    var mobileApply = document.getElementById("mobile-filter-apply");

    // Read only from a specific panel to avoid desktop+mobile duplication
    function buildFiltersFromPanel(panel) {
      var groups = {};
      panel.querySelectorAll(".filter-checkbox:checked").forEach(function (cb) {
        var key = cb.getAttribute("data-group") || cb.name;
        if (!groups[key]) groups[key] = [];
        groups[key].push(cb.value);
      });
      return Object.keys(groups)
        .map(function (k) { return k + ":" + groups[k].join("|"); })
        .join(",");
    }

    function navigateWithFilters(filtersStr) {
      var url = new URL(window.location.origin + "/products");
      if (filtersStr) url.searchParams.set("filters", filtersStr);
      window.location.href = url.toString();
    }

    // ── Mobile filter panel ──
    function openMobileFilters() {
      if (!mobileFilterPanel || !mobileFilterScrim) return;
      mobileFilterPanel.classList.add("open");
      mobileFilterScrim.style.opacity = "1";
      mobileFilterScrim.style.pointerEvents = "auto";
      document.body.style.overflow = "hidden";
    }

    function closeMobileFilters() {
      if (!mobileFilterPanel || !mobileFilterScrim) return;
      mobileFilterPanel.classList.remove("open");
      mobileFilterScrim.style.opacity = "0";
      mobileFilterScrim.style.pointerEvents = "none";
      document.body.style.overflow = "";
    }

    if (mobileToggle) mobileToggle.addEventListener("click", function (e) {
      e.preventDefault();
      openMobileFilters();
    });
    if (mobileClose) mobileClose.addEventListener("click", function (e) {
      e.preventDefault();
      closeMobileFilters();
    });
    if (mobileFilterScrim) mobileFilterScrim.addEventListener("click", closeMobileFilters);

    if (mobileApply) mobileApply.addEventListener("click", function (e) {
      e.preventDefault();
      closeMobileFilters();
      navigateWithFilters(buildFiltersFromPanel(mobileFilterPanel));
    });

    // Desktop filter checkbox change -> read only desktop panel -> navigate
    if (desktopFilterPanel) {
      desktopFilterPanel.querySelectorAll(".filter-checkbox").forEach(function (cb) {
        cb.addEventListener("change", function () {
          navigateWithFilters(buildFiltersFromPanel(desktopFilterPanel));
        });
      });
    }
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initFilters);
  } else {
    initFilters();
  }
})();
</script>

<style is:inline>
  #mobile-filter-panel.open {
    transform: translateX(0) !important;
  }
</style>
