---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/ui/Breadcrumb.astro";
import ProductCard from "../../components/ui/ProductCard.astro";
import StarRating from "../../components/ui/StarRating.astro";
import { AddToCartButton, BuyNowButton } from "../../components/ui/buttons";
import { formatPrice, safeParseArray } from "../../lib/utils";
import { api } from "../../lib/api";

// 1. Static paths generation for SSG — fetch ALL products across all pages
export async function getStaticPaths() {
  const PAGE_SIZE = 100;
  let allProducts: { slug: string }[] = [];
  let page = 1;
  let totalPages = 1;

  try {
    // First request to get total count
    const firstPage = await api.getAllProducts(page, PAGE_SIZE);
    allProducts = (firstPage.result || []).map((prod) => ({ slug: prod.slug }));
    totalPages = firstPage.totalPages || 1;

    // Fetch remaining pages in parallel batches of 4
    while (page < totalPages) {
      const batch: number[] = [];
      for (let i = 1; i <= 4 && page + i <= totalPages; i++) {
        batch.push(page + i);
      }

      const results = await Promise.all(
        batch.map((p) => api.getAllProducts(p, PAGE_SIZE))
      );

      for (const data of results) {
        const slugs = (data.result || []).map((prod) => ({ slug: prod.slug }));
        allProducts.push(...slugs);
      }

      page += batch.length;
    }

    console.log(`[getStaticPaths] Generated ${allProducts.length} product paths`);

    return allProducts.map(({ slug }) => ({
      params: { slug },
    }));
  } catch (error) {
    console.error("Error generating static paths for products:", error);
    // Return whatever we managed to fetch
    return allProducts.map(({ slug }) => ({
      params: { slug },
    }));
  }
}

const { slug } = Astro.params;

import type { Product } from "../../lib/api";

// 2. Fetch specific product content
let product: Product | null = null;
let relatedProducts: Product[] = [];
let brandProducts: Product[] = [];

try {
  product = await api.getProductBySlug(slug);
  relatedProducts = await api.getRandomProducts(4);
  if (product?.brand_slug) {
    const brandData = await api.getProductsByBrand(product.brand_slug, 1, 8);
    brandProducts = (brandData.result || []).filter(p => p.id !== product.id).slice(0, 4);
  }
} catch (error) {
  console.error(`Error loading product slug "${slug}" from backend:`, error);
}

if (!product) {
  return Astro.redirect("/404");
}

const currentPrice = parseFloat(product.price);
const originalPrice = parseFloat(product.origin_price);
const onSale = originalPrice > currentPrice;
const discountPercent = onSale ? Math.round(((originalPrice - currentPrice) / originalPrice) * 100) : 0;

// Setup image gallery sources
const mainImg = product.img || product.card_photo;
const photosList = safeParseArray(product.details?.photos);
const galleryImages = [mainImg, ...photosList].filter(Boolean);

// Parse details arrays safely
const benefits = safeParseArray(product.details?.benefits);
const howToUse = safeParseArray(product.details?.how_to_use);
const sizes = safeParseArray(product.details?.sizes);
---

<BaseLayout
  title={`${product.name} | TOK Skincare Bangladesh`}
  description={`Shop authentic ${product.brand} - ${product.name} imported directly from Bangkok. ${product.details?.description?.slice(0, 120)}...`}
  image={mainImg}
>
  <div class="max-w-[1536px] mx-auto px-4 md:px-6 pt-4 pb-16 md:pb-24">
    {/* Breadcrumbs */}
    <Breadcrumb
      items={[
        { label: "Home", href: "/" },
        { label: product.brand, href: `/brands/${product.brand_slug}` },
        { label: product.category, href: `/categories/${product.category_slug}` },
        { label: product.name },
      ]}
    />

    {/* ═══ PDP 2-column layout ═══ */}
    <div class="grid grid-cols-1 lg:grid-cols-[42fr_58fr] gap-8 lg:gap-14 items-start mb-16 md:mb-24 overflow-hidden">

      {/* ── Image Gallery Column ── */}
      <div class="flex flex-col gap-3 min-w-0">
        <div class="relative w-full pt-[133.33%] bg-surface-card border border-hairline overflow-hidden">
          <img src={mainImg} alt={product.name} class="absolute inset-0 w-full h-full object-cover" id="pdp-main-image" />

          {/* Badges */}
          <div class="absolute top-3 left-3 flex flex-col gap-1.5 z-10">
            {onSale && (
              <span class="inline-flex items-center font-sans text-[10px] font-bold tracking-[1.5px] uppercase px-3 py-1.5 leading-none bg-ink text-on-dark">
                -{discountPercent}% OFF
              </span>
            )}
            {!product.stock && (
              <span class="inline-flex items-center font-sans text-[10px] font-bold tracking-[1.5px] uppercase px-3 py-1.5 leading-none bg-mute text-on-primary">
                SOLD OUT
              </span>
            )}
            {product.origin_country === "thailand" && (
              <span class="inline-flex items-center font-sans text-[10px] font-bold tracking-[1.5px] uppercase px-3 py-1.5 leading-none bg-primary text-on-primary">
                100% THAI
              </span>
            )}
          </div>
        </div>

        {/* Thumbnail strip */}
        {galleryImages.length > 1 && (
          <div class="flex gap-2 overflow-x-auto pb-1">
            {galleryImages.map((img, idx) => (
              <button
                class:list={[
                  "w-[60px] h-[80px] md:w-[70px] md:h-[93px] border shrink-0 p-0 cursor-pointer overflow-hidden bg-canvas transition-colors",
                  idx === 0 ? "border-primary outline-1 outline-primary" : "border-hairline",
                ]}
                data-img-url={img}
                aria-label={`View photo ${idx + 1}`}
              >
                <img src={img} alt="" class="w-full h-full object-cover" />
              </button>
            ))}
          </div>
        )}
      </div>

      {/* ── Info Column ── */}
      <div class="flex flex-col min-w-0">
        {/* Brand + Category */}
        <div class="flex items-center gap-1.5 mb-1.5 flex-wrap">
          <a href={`/brands/${product.brand_slug}`} class="font-sans text-[11px] font-bold tracking-[2px] uppercase text-primary no-underline hover:text-primary-pressed transition-colors">{product.brand}</a>
          <span class="text-stone text-[11px]">&bull;</span>
          <a href={`/categories/${product.category_slug}`} class="font-sans text-[11px] font-bold tracking-[2px] uppercase text-mute no-underline hover:text-primary transition-colors">{product.category}</a>
        </div>

        {/* Title */}
        <h1 class="font-serif text-[28px] md:text-[36px] lg:text-[40px] font-bold text-ink leading-tight m-0 mb-2">{product.name}</h1>

        {/* Ratings */}
        <div class="flex items-center gap-2 mb-5 flex-wrap">
          <StarRating rating={4.5} count={14} size={16} />
          <span class="text-stone">&bull;</span>
          <span class="font-sans text-[12px] text-mute uppercase tracking-[0.5px]">Imported from {product.origin_country}</span>
        </div>

        {/* Pricing */}
        <div class="border-t border-b border-hairline py-3 mb-5 flex items-baseline gap-4 flex-wrap">
          <span class="font-sans text-[28px] md:text-[32px] font-bold text-ink leading-none">{formatPrice(product.price)}</span>
          {onSale && (
            <div class="flex items-center gap-2 flex-wrap">
              <span class="font-sans text-[18px] md:text-[20px] text-ash line-through">{formatPrice(product.origin_price)}</span>
              <span class="font-sans text-[11px] font-bold text-success-deep bg-success-pale px-1.5 py-0.5 uppercase tracking-[0.5px]">Save {formatPrice(originalPrice - currentPrice)}</span>
            </div>
          )}
        </div>

        {/* Size / Variant Selector */}
        {sizes.length > 0 && (
          <div class="mb-5">
            <h3 class="font-sans text-[12px] font-bold tracking-[1px] uppercase text-ink mb-2 m-0">Select Size</h3>
            <div class="flex gap-1.5 flex-wrap">
              {sizes.map((size, idx) => (
                <button class:list={[
                  "border font-sans text-[13px] px-4 py-2 bg-canvas cursor-pointer transition-colors",
                  idx === 0 ? "border-ink bg-ink text-on-dark" : "border-stone text-ink hover:border-ink",
                ]}>
                  {size}
                </button>
              ))}
            </div>
          </div>
        )}

        {/* Purchase Box */}
        <div class="mb-8">
          {product.stock ? (
            <div class="flex flex-col gap-3">
              {/* Quantity Section */}
              <div class="flex items-center gap-3">
                <span class="font-sans text-[12px] font-bold tracking-[1px] text-mute uppercase">Quantity</span>
                <div class="flex items-center border border-stone h-10 bg-canvas">
                  <button class="w-9 h-full flex items-center justify-center font-bold text-[16px] cursor-pointer hover:bg-surface-soft transition-colors bg-transparent border-none" id="pdp-qty-dec" aria-label="Decrease quantity">-</button>
                  <span class="w-9 text-center font-sans text-[14px] font-bold" id="pdp-qty-val">1</span>
                  <button class="w-9 h-full flex items-center justify-center font-bold text-[16px] cursor-pointer hover:bg-surface-soft transition-colors bg-transparent border-none" id="pdp-qty-inc" aria-label="Increase quantity">+</button>
                </div>
              </div>

              {/* CTA Buttons Row */}
              <div class="flex flex-col sm:flex-row gap-2 w-full">
                <AddToCartButton
                  id="pdp-add-to-bag-btn"
                  productId={product.id}
                  name={product.name}
                  price={currentPrice}
                  image={mainImg || ""}
                  slug={product.slug}
                  quantity={1}
                />
                <BuyNowButton
                  id="pdp-buy-now-btn"
                  productId={product.id}
                  name={product.name}
                  price={currentPrice}
                  image={mainImg || ""}
                  slug={product.slug}
                  quantity={1}
                />
              </div>
            </div>
          ) : (
            <div class="bg-surface-card border border-hairline p-4">
              <h3 class="font-sans text-[14px] font-bold uppercase text-ink mb-1.5 m-0">Currently Sold Out</h3>
              <p class="font-sans text-[13px] text-mute leading-relaxed m-0">We restock direct shipments from Bangkok every two weeks.</p>
            </div>
          )}
        </div>

        {/* Tabbed Information Panel */}
        <div class="border-t border-hairline pt-4">
          <div class="flex gap-3 border-b border-hairline mb-3 overflow-x-auto" role="tablist" style="scrollbar-width:none">
            <button class="tab-btn font-sans text-[13px] font-bold tracking-[1px] uppercase text-mute bg-transparent border-none py-1.5 pb-2 cursor-pointer relative whitespace-nowrap transition-colors hover:text-ink active" data-tab="description" role="tab" aria-selected="true">Description</button>
            {product.details?.key_ingredient && (
              <button class="tab-btn font-sans text-[13px] font-bold tracking-[1px] uppercase text-mute bg-transparent border-none py-1.5 pb-2 cursor-pointer relative whitespace-nowrap transition-colors hover:text-ink" data-tab="ingredients" role="tab" aria-selected="false">Key Ingredients</button>
            )}
            {howToUse.length > 0 && (
              <button class="tab-btn font-sans text-[13px] font-bold tracking-[1px] uppercase text-mute bg-transparent border-none py-1.5 pb-2 cursor-pointer relative whitespace-nowrap transition-colors hover:text-ink" data-tab="howtouse" role="tab" aria-selected="false">How To Use</button>
            )}
            {benefits.length > 0 && (
              <button class="tab-btn font-sans text-[13px] font-bold tracking-[1px] uppercase text-mute bg-transparent border-none py-1.5 pb-2 cursor-pointer relative whitespace-nowrap transition-colors hover:text-ink" data-tab="benefits" role="tab" aria-selected="false">Key Benefits</button>
            )}
          </div>

          <div class="min-h-[80px] pt-1">
            <div class="tab-panel font-sans text-[14px] text-body leading-relaxed active" id="tab-description-content" role="tabpanel">
              <p class="m-0">{product.details?.description || "Authentic skincare product imported directly from Thailand. Formulated with premium ingredients to support clear, glowing, and balanced skin."}</p>
            </div>

            {product.details?.key_ingredient && (
              <div class="tab-panel font-sans text-[14px] text-body leading-relaxed" id="tab-ingredients-content" role="tabpanel">
                <p class="m-0 tracking-[0.2px]">{product.details?.key_ingredient}</p>
              </div>
            )}

            {howToUse.length > 0 && (
              <div class="tab-panel font-sans text-[14px] text-body leading-relaxed" id="tab-howtouse-content" role="tabpanel">
                <ol class="pl-4 m-0 flex flex-col gap-1.5">
                  {howToUse.map(step => <li>{step}</li>)}
                </ol>
              </div>
            )}

            {benefits.length > 0 && (
              <div class="tab-panel font-sans text-[14px] text-body leading-relaxed" id="tab-benefits-content" role="tabpanel">
                <ul class="pl-4 m-0 flex flex-col gap-1.5">
                  {benefits.map(benefit => <li>{benefit}</li>)}
                </ul>
              </div>
            )}
          </div>
        </div>
      </div>
    </div>

    {/* ═══ Brand Products ═══ */}
    {brandProducts.length > 0 && (
      <section class="border-t border-hairline pt-12 md:pt-16 mb-12 md:mb-16">
        <div class="mb-6 md:mb-8">
          <span class="font-sans text-[11px] font-bold tracking-[2.5px] uppercase text-primary leading-none">FROM THE SAME BRAND</span>
          <h2 class="font-serif text-[28px] md:text-[36px] font-bold text-ink m-0 mt-2">More from {product.brand}</h2>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-3 xl:grid-cols-4 gap-1 sm:gap-2">
          {brandProducts.map(prod => <ProductCard product={prod} />)}
        </div>
      </section>
    )}

    {/* ═══ Related Products ═══ */}
    <section class="border-t border-hairline pt-12 md:pt-16">
      <div class="mb-6 md:mb-8">
        <span class="font-sans text-[11px] font-bold tracking-[2.5px] uppercase text-primary leading-none">RITUAL PAIRINGS</span>
        <h2 class="font-serif text-[28px] md:text-[36px] font-bold text-ink m-0 mt-2">Recommended Products</h2>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-3 xl:grid-cols-4 gap-1 sm:gap-2">
        {relatedProducts.map(prod => <ProductCard product={prod} />)}
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .tab-btn.active {
    color: var(--color-ink, #1A0E14);
  }
  .tab-btn.active::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 100%;
    height: 2px;
    background-color: var(--color-ink, #1A0E14);
  }
  .tab-panel {
    display: none;
    animation: fadeIn 0.25s ease;
  }
  .tab-panel.active {
    display: block;
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(4px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // 1. Gallery thumbnail selectors
    const mainImage = document.getElementById('pdp-main-image') as HTMLImageElement;
    const thumbs = document.querySelectorAll('[data-img-url]');

    thumbs.forEach((btn) => {
      btn.addEventListener('click', (e) => {
        thumbs.forEach((t) => {
          t.classList.remove('border-primary');
          t.classList.add('border-hairline');
          (t as HTMLElement).style.outline = '';
        });

        const target = e.currentTarget as HTMLElement;
        target.classList.remove('border-hairline');
        target.classList.add('border-primary');
        target.style.outline = '1px solid var(--color-primary, #C8365A)';

        const newUrl = target.getAttribute('data-img-url');
        if (newUrl && mainImage) {
          mainImage.src = newUrl;
        }
      });
    });

    // 2. Quantity selector
    const valSpan = document.getElementById('pdp-qty-val');
    const decBtn = document.getElementById('pdp-qty-dec');
    const incBtn = document.getElementById('pdp-qty-inc');
    const addBtn = document.getElementById('pdp-add-to-bag-btn');
    const buyBtn = document.getElementById('pdp-buy-now-btn');

    let qty = 1;

    function updateQtyButtons() {
      if (addBtn) addBtn.setAttribute('data-qty', qty.toString());
      if (buyBtn) buyBtn.setAttribute('data-qty', qty.toString());
    }

    decBtn?.addEventListener('click', () => {
      if (qty > 1) {
        qty--;
        if (valSpan) valSpan.innerText = qty.toString();
        updateQtyButtons();
      }
    });

    incBtn?.addEventListener('click', () => {
      qty++;
      if (valSpan) valSpan.innerText = qty.toString();
      updateQtyButtons();
    });

    // 3. Tab switcher logic
    const tabBtns = document.querySelectorAll('.tab-btn');
    const tabPanels = document.querySelectorAll('.tab-panel');

    tabBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        tabBtns.forEach((b) => {
          b.classList.remove('active');
          b.setAttribute('aria-selected', 'false');
        });
        tabPanels.forEach((p) => p.classList.remove('active'));

        btn.classList.add('active');
        btn.setAttribute('aria-selected', 'true');

        const targetTab = btn.getAttribute('data-tab');
        const targetPanel = document.getElementById(`tab-${targetTab}-content`);
        if (targetPanel) {
          targetPanel.classList.add('active');
        }
      });
    });
  });
</script>
