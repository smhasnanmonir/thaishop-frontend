---
export const prerender = false;
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/ui/Breadcrumb.astro";
import ProductCard from "../../components/ui/ProductCard.astro";
import StarRating from "../../components/ui/StarRating.astro";
import { AddToCartButton, BuyNowButton } from "../../components/ui/buttons";
import { MessengerButton, WhatsAppButton } from "../../components/ui/messenger";
import { ProductSchema, BreadcrumbSchema } from "../../components/seo";
import { formatPrice, safeParseArray } from "../../lib/utils";
import { api } from "../../lib/api";
import type { Product } from "../../lib/api";

const { slug } = Astro.params;

let product: Product | null = null;
let relatedProducts: Product[] = [];
let brandProducts: Product[] = [];

try {
  product = await api.getProductBySlug(slug);

  if (product?.category_slug) {
    try {
      const cat = await api.getProductsByCategory(product.category_slug, 1, 8);
      const filtered = (cat.result || []).filter((p) => p.id !== product!.id).slice(0, 6);
      if (filtered.length > 0) relatedProducts = filtered;
    } catch (e) {
      console.warn("Category-based related lookup failed, falling back to random:", e);
    }
  }
  if (relatedProducts.length === 0) {
    relatedProducts = await api.getRandomProducts(6);
  }

  if (product?.brand_slug) {
    const brandData = await api.getProductsByBrand(product.brand_slug, 1, 10);
    brandProducts = (brandData.result || []).filter(p => p.id !== product!.id).slice(0, 6);
  }
} catch (error) {
  console.error(`Error loading product slug "${slug}" from backend:`, error);
}

if (!product) {
  return Astro.redirect("/404");
}

const currentPrice = parseFloat(product.price);
const originalPrice = parseFloat(product.origin_price);
const onSale = originalPrice > currentPrice;
const discountPercent = onSale ? Math.round(((originalPrice - currentPrice) / originalPrice) * 100) : 0;

const mainImg = product.img || product.card_photo;
const photosList = safeParseArray(product.details?.photos);
const galleryImages = [mainImg, ...photosList].filter(Boolean);

const benefits = safeParseArray(product.details?.benefits);
const howToUse = safeParseArray(product.details?.how_to_use);
const sizes = safeParseArray(product.details?.sizes);

const originCountry = product.origin_country || "Thailand";
const deliveryText = "Inside Dhaka: 1-2 Days \u2022 Outside Dhaka: 3-5 Days";
---

<BaseLayout
  title={`${product.name} | TOK Skincare Bangladesh`}
  description={`Shop authentic ${product.brand} - ${product.name} imported directly from Bangkok. ${product.details?.description?.slice(0, 120)}...`}
  image={mainImg}
  type="product"
>
  <Fragment slot="head">
    <ProductSchema product={product} rating={{ value: 4.5, count: 0 }} />
    <BreadcrumbSchema
      items={[
        { label: "Home", href: "/" },
        { label: product.brand, href: `/brands/${product.brand_slug}` },
        { label: product.category, href: `/categories/${product.category_slug}` },
        { label: product.name },
      ]}
    />
  </Fragment>

  <div class="max-w-[1536px] mx-auto px-[3%] md:px-6 pt-4 pb-16 md:pb-24">
    {/* Breadcrumbs */}
    <div class="mt-4 mb-6">
      <Breadcrumb
        items={[
          { label: "Home", href: "/" },
          { label: product.brand, href: `/brands/${product.brand_slug}` },
          { label: product.category, href: `/categories/${product.category_slug}` },
          { label: product.name },
        ]}
      />
    </div>

    {/* ═══ PDP 2-column layout ═══ */}
    <div class="grid grid-cols-1 lg:grid-cols-[42fr_58fr] gap-8 lg:gap-14 items-start mb-12 md:mb-16 overflow-hidden">

      {/* ── Image Gallery Column ── */}
      <div class="flex flex-col gap-3 min-w-0">
        <div class="relative w-full pt-[80%] sm:pt-[90%] md:pt-[100%] bg-surface-card border border-hairline overflow-hidden">
          <img src={mainImg} alt={product.name} class="absolute inset-0 w-full h-full object-cover" id="pdp-main-image" />

          <div class="absolute top-3 left-3 flex flex-col gap-1.5 z-10">
            {onSale && (
              <span class="inline-flex items-center font-sans text-[10px] font-bold tracking-[1.5px] uppercase px-3 py-1.5 leading-none bg-ink text-on-dark">
                -{discountPercent}% OFF
              </span>
            )}
            {!product.stock && (
              <span class="inline-flex items-center font-sans text-[10px] font-bold tracking-[1.5px] uppercase px-3 py-1.5 leading-none bg-mute text-on-primary">
                SOLD OUT
              </span>
            )}
          </div>
        </div>

        {galleryImages.length > 1 && (
          <div class="flex gap-2 overflow-x-auto pb-1">
            {galleryImages.map((img, idx) => (
              <button
                class:list={[
                  "w-[60px] h-[80px] md:w-[70px] md:h-[93px] border shrink-0 p-0 cursor-pointer overflow-hidden bg-canvas transition-colors",
                  idx === 0 ? "border-primary outline-1 outline-primary" : "border-hairline",
                ]}
                data-img-url={img}
                aria-label={`View photo ${idx + 1}`}
              >
                <img src={img} alt="" class="w-full h-full object-cover" />
              </button>
            ))}
          </div>
        )}
      </div>

      {/* ── Info Column ── */}
      <div class="flex flex-col min-w-0">
        {/* Brand / Category / Stock */}
        <div class="flex items-center gap-2 mb-2 flex-wrap text-[12px] font-sans uppercase tracking-[0.5px]">
          <a href={`/brands/${product.brand_slug}`} class="text-primary font-bold no-underline hover:text-primary-pressed transition-colors">{product.brand}</a>
          <span class="text-stone">&bull;</span>
          <a href={`/categories/${product.category_slug}`} class="text-mute font-semibold no-underline hover:text-primary transition-colors">{product.category}</a>
          <span class="text-stone">&bull;</span>
          <span class="flex items-center gap-1 font-semibold text-success-deep">
            <span class={`w-1.5 h-1.5 rounded-full ${product.stock ? "bg-success-deep" : "bg-mute"}`}></span>
            {product.stock ? "In Stock" : "Out of Stock"}
          </span>
        </div>

        {/* Title */}
        <h1 class="font-serif text-[26px] md:text-[34px] lg:text-[40px] font-bold text-ink leading-tight m-0 mb-3">{product.name}</h1>

        {/* Ratings */}
        <div class="flex items-center gap-2 mb-4 flex-wrap">
          <StarRating rating={4.5} count={0} size={16} />
          <span class="text-stone">&bull;</span>
          <span class="font-sans text-[12px] text-mute uppercase tracking-[0.5px]">Imported from {originCountry}</span>
        </div>

        {/* Pricing */}
        <div class="border-t border-b border-hairline py-3 mb-5 flex flex-wrap items-baseline gap-3">
          <span class="font-sans text-[30px] md:text-[34px] font-bold text-ink leading-none">{formatPrice(product.price)}</span>
          {onSale && (
            <>
              <span class="font-sans text-[16px] md:text-[18px] text-ash line-through">{formatPrice(product.origin_price)}</span>
              <span class="font-sans text-[11px] font-bold text-white bg-primary px-2 py-0.5 rounded-none">{discountPercent}% OFF</span>
            </>
          )}
        </div>

        {/* Expiry + Sizes */}
        <div class="grid grid-cols-2 gap-4 mb-5">
          {product.expiry_date && (
            <div>
              <span class="block font-sans text-[11px] font-bold tracking-[1px] uppercase text-mute mb-1">Expiry Date</span>
              <span class="font-sans text-[14px] font-semibold text-ink">{product.expiry_date}</span>
            </div>
          )}
          {sizes.length > 0 && (
            <div>
              <span class="block font-sans text-[11px] font-bold tracking-[1px] uppercase text-mute mb-1">Available Sizes</span>
              <div class="flex gap-1.5 flex-wrap">
                {sizes.map((size) => (
                  <button class="border border-stone px-3 py-1 font-sans text-[13px] text-ink bg-canvas hover:border-ink transition-colors cursor-pointer">
                    {size}
                  </button>
                ))}
              </div>
            </div>
          )}
        </div>

        {/* Purchase Actions */}
        {product.stock ? (
          <div class="flex flex-col gap-3 mb-5">
            {/* Quantity */}
            <div class="flex items-center gap-3">
              <span class="font-sans text-[12px] font-bold tracking-[1px] text-mute uppercase">Quantity</span>
              <div class="flex items-center border border-stone h-10 bg-canvas">
                <button class="w-9 h-full flex items-center justify-center font-bold text-[16px] cursor-pointer hover:bg-surface-soft transition-colors bg-transparent border-none" id="pdp-qty-dec" aria-label="Decrease quantity">-</button>
                <span class="w-9 text-center font-sans text-[14px] font-bold" id="pdp-qty-val">1</span>
                <button class="w-9 h-full flex items-center justify-center font-bold text-[16px] cursor-pointer hover:bg-surface-soft transition-colors bg-transparent border-none" id="pdp-qty-inc" aria-label="Increase quantity">+</button>
              </div>
            </div>

            {/* CTA Buttons */}
            <div class="grid grid-cols-[1fr_1fr_auto] gap-2 w-full">
              <AddToCartButton
                id="pdp-add-to-bag-btn"
                productId={product.id}
                name={product.name}
                price={currentPrice}
                image={mainImg || ""}
                slug={product.slug}
                quantity={1}
              />
              <BuyNowButton
                id="pdp-buy-now-btn"
                productId={product.id}
                name={product.name}
                price={currentPrice}
                image={mainImg || ""}
                slug={product.slug}
                quantity={1}
              />
              <button
                id="pdp-wishlist-btn"
                class="w-12 h-12 sm:h-auto flex items-center justify-center border border-hairline bg-canvas text-primary hover:bg-surface-blush transition-colors cursor-pointer"
                aria-label="Add to wishlist"
                data-product-id={product.id}
              >
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
              </button>
            </div>
          </div>
        ) : (
          <div class="bg-surface-card border border-hairline p-4 mb-5">
            <h3 class="font-sans text-[14px] font-bold uppercase text-ink mb-1.5 m-0">Currently Sold Out</h3>
            <p class="font-sans text-[13px] text-mute leading-relaxed m-0">We restock direct shipments from Bangkok every two weeks.</p>
          </div>
        )}

        {/* Messenger + WhatsApp */}
        <div class="grid grid-cols-2 gap-2 mb-4">
          <MessengerButton fullWidth={true} />
          <WhatsAppButton fullWidth={true} />
        </div>

        {/* Delivery Timescale */}
        <div class="flex items-center gap-2 bg-surface-soft border border-hairline-soft px-4 py-3 mb-6">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-mute shrink-0"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
          <span class="font-sans text-[13px] text-ink font-medium">Delivery Timescale: <span class="text-mute">{deliveryText}</span></span>
        </div>
      </div>
    </div>

    {/* ═══ Information Accordion (bottom) ═══ */}
    <div class="border-t border-hairline pt-4 mb-16 md:mb-24" id="pdp-accordion">
      {/* Description */}
      <div class="accordion-item border-b border-hairline-soft">
        <button class="accordion-trigger w-full flex items-center justify-between py-3 font-sans text-[13px] font-bold tracking-[1px] uppercase text-ink bg-transparent border-none cursor-pointer text-left" data-accordion="description" aria-expanded="true">
          <span>Description</span>
          <svg class="accordion-icon transition-transform duration-200" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"></polyline></svg>
        </button>
        <div class="accordion-content font-sans text-[14px] text-body leading-relaxed" id="acc-description">
          <p class="m-0 pb-4">{product.details?.description || "Authentic skincare product imported directly from Thailand. Formulated with premium ingredients to support clear, glowing, and balanced skin."}</p>
        </div>
      </div>

      {/* Key Ingredients */}
      {product.details?.key_ingredient && (
        <div class="accordion-item border-b border-hairline-soft">
          <button class="accordion-trigger w-full flex items-center justify-between py-3 font-sans text-[13px] font-bold tracking-[1px] uppercase text-ink bg-transparent border-none cursor-pointer text-left" data-accordion="ingredients" aria-expanded="false">
            <span>Key Ingredients</span>
            <svg class="accordion-icon transition-transform duration-200" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"></polyline></svg>
          </button>
          <div class="accordion-content font-sans text-[14px] text-body leading-relaxed hidden" id="acc-ingredients">
            <p class="m-0 pb-4 tracking-[0.2px]">{product.details?.key_ingredient}</p>
          </div>
        </div>
      )}

      {/* How To Use */}
      {howToUse.length > 0 && (
        <div class="accordion-item border-b border-hairline-soft">
          <button class="accordion-trigger w-full flex items-center justify-between py-3 font-sans text-[13px] font-bold tracking-[1px] uppercase text-ink bg-transparent border-none cursor-pointer text-left" data-accordion="howtouse" aria-expanded="false">
            <span>How To Use</span>
            <svg class="accordion-icon transition-transform duration-200" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"></polyline></svg>
          </button>
          <div class="accordion-content font-sans text-[14px] text-body leading-relaxed hidden" id="acc-howtouse">
            <ol class="pl-4 m-0 pb-4 flex flex-col gap-1.5">
              {howToUse.map(step => <li>{step}</li>)}
            </ol>
          </div>
        </div>
      )}

      {/* Key Benefits */}
      {benefits.length > 0 && (
        <div class="accordion-item border-b border-hairline-soft last:border-b-0">
          <button class="accordion-trigger w-full flex items-center justify-between py-3 font-sans text-[13px] font-bold tracking-[1px] uppercase text-ink bg-transparent border-none cursor-pointer text-left" data-accordion="benefits" aria-expanded="false">
            <span>Key Benefits</span>
            <svg class="accordion-icon transition-transform duration-200" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"></polyline></svg>
          </button>
          <div class="accordion-content font-sans text-[14px] text-body leading-relaxed hidden" id="acc-benefits">
            <ul class="pl-4 m-0 pb-4 flex flex-col gap-1.5">
              {benefits.map(benefit => <li>{benefit}</li>)}
            </ul>
          </div>
        </div>
      )}
    </div>

    {/* ═══ Brand Products ═══ */}
    {brandProducts.length > 0 && (
      <section class="border-t border-hairline pt-12 md:pt-16 mb-12 md:mb-16">
        <div class="mb-6 md:mb-8">
          <span class="font-sans text-[11px] font-bold tracking-[2.5px] uppercase text-primary leading-none">FROM THE SAME BRAND</span>
          <h2 class="font-serif text-[28px] md:text-[36px] font-bold text-ink m-0 mt-2">More from {product.brand}</h2>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-3 xl:grid-cols-6 gap-2 sm:gap-3">
          {brandProducts.map(prod => <ProductCard product={prod} />)}
        </div>
      </section>
    )}

    {/* ═══ Related Products ═══ */}
    <section class="border-t border-hairline pt-12 md:pt-16">
      <div class="mb-6 md:mb-8">
        <span class="font-sans text-[11px] font-bold tracking-[2.5px] uppercase text-primary leading-none">RITUAL PAIRINGS</span>
        <h2 class="font-serif text-[28px] md:text-[36px] font-bold text-ink m-0 mt-2">Recommended Products</h2>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-3 xl:grid-cols-6 gap-2 sm:gap-3">
        {relatedProducts.map(prod => <ProductCard product={prod} />)}
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .accordion-content {
    animation: fadeIn 0.25s ease;
  }
  .accordion-trigger[aria-expanded="true"] .accordion-icon {
    transform: rotate(180deg);
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(-4px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<script>
  function initProductPage() {
    const mainImage = document.getElementById('pdp-main-image') as HTMLImageElement;
    const thumbs = document.querySelectorAll('[data-img-url]');

    thumbs.forEach((btn) => {
      btn.addEventListener('click', (e) => {
        thumbs.forEach((t) => {
          t.classList.remove('border-primary');
          t.classList.add('border-hairline');
          (t as HTMLElement).style.outline = '';
        });

        const target = e.currentTarget as HTMLElement;
        target.classList.remove('border-hairline');
        target.classList.add('border-primary');
        target.style.outline = '1px solid var(--color-primary, #C8365A)';

        const newUrl = target.getAttribute('data-img-url');
        if (newUrl && mainImage) mainImage.src = newUrl;
      });
    });

    const valSpan = document.getElementById('pdp-qty-val');
    const decBtn = document.getElementById('pdp-qty-dec');
    const incBtn = document.getElementById('pdp-qty-inc');
    const addBtn = document.getElementById('pdp-add-to-bag-btn');
    const buyBtn = document.getElementById('pdp-buy-now-btn');
    const wishlistBtn = document.getElementById('pdp-wishlist-btn');

    let qty = 1;

    function updateQtyButtons() {
      if (addBtn) addBtn.setAttribute('data-qty', qty.toString());
      if (buyBtn) buyBtn.setAttribute('data-qty', qty.toString());
    }

    decBtn?.addEventListener('click', () => {
      if (qty > 1) {
        qty--;
        if (valSpan) valSpan.innerText = qty.toString();
        updateQtyButtons();
      }
    });

    incBtn?.addEventListener('click', () => {
      qty++;
      if (valSpan) valSpan.innerText = qty.toString();
      updateQtyButtons();
    });

    // Wishlist
    wishlistBtn?.addEventListener('click', () => {
      wishlistBtn.classList.toggle('bg-surface-blush');
      wishlistBtn.classList.toggle('text-primary');
      const svg = wishlistBtn.querySelector('svg');
      if (svg) {
        const isFilled = svg.getAttribute('fill') === 'currentColor';
        svg.setAttribute('fill', isFilled ? 'none' : 'currentColor');
      }
    });

    // Accordion - description open by default, others collapsed
    const accordionBtns = document.querySelectorAll('.accordion-trigger');

    accordionBtns.forEach((btn) => {
      const targetId = 'acc-' + btn.getAttribute('data-accordion');
      const content = document.getElementById(targetId);
      if (!content) return;

      // Only set initial state for non-description accordions
      const isDescription = btn.getAttribute('data-accordion') === 'description';
      if (!isDescription) {
        btn.setAttribute('aria-expanded', 'false');
        content.classList.add('hidden');
      }

      btn.addEventListener('click', () => {
        const isExpanded = btn.getAttribute('aria-expanded') === 'true';
        btn.setAttribute('aria-expanded', String(!isExpanded));
        content.classList.toggle('hidden');
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initProductPage);
  } else {
    initProductPage();
  }
</script>
